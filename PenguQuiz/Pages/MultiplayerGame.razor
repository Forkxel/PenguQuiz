@page "/multiplayerGame/{Code}"
@using WebQuizGame.Classes.Models
@using WebQuizGame.Classes.Models.Multiplayer
@using WebQuizGame.Classes.Services
@using Microsoft.AspNetCore.Components.Routing
@using System.Globalization
@inject MultiplayerClient Mp
@inject NavigationManager Nav
@inject IJSRuntime JS
@implements IDisposable

<NavigationLock OnBeforeInternalNavigation="ConfirmLeaveNavigation" />

<div class="multiplayer-game-page">
    <button class="home-floating-btn home-with-text" @onclick="GoHome" title="Home">
        <img src="/images/avatars/macaroni.png" alt="Home" class="home-floating-img" />
        <span>Home</span>
    </button>

    <div class="game-layout">
        <aside class="game-sidebar">
            @if (LiveScores.Any())
            {
                @foreach (var player in LiveScores)
                {
                    <div class="game-player" style="border-left: 4px solid @player.PlayerColor;">
                        <div class="game-avatar-wrap">
                            <img class="game-avatar"
                                 src="@GetAvatarUrl(player.AvatarKey)"
                                 alt="avatar" />
                        </div>

                        <div class="game-player-info">
                            <span class="game-player-name">
                                <span class="multiplayer-player-color-dot" style="background:@player.PlayerColor;"></span>
                                @player.Username
                            </span>
                            <span class="game-player-score">@player.Score</span>
                        </div>
                    </div>
                }
            }
            else if (Scores.Any())
            {
                @foreach (var s in Scores.OrderByDescending(x => x.Value))
                {
                    <div class="game-player" style="border-left: 4px solid @GetPlayerColor(s.Key);">
                        <div class="game-avatar-wrap">
                            <img class="game-avatar"
                                 src="@GetAvatarUrl("default")"
                                 alt="avatar" />
                        </div>

                        <div class="game-player-info">
                            <span class="game-player-name">
                                <span class="multiplayer-player-color-dot" style="background:@GetPlayerColor(s.Key);"></span>
                                @s.Key
                            </span>
                            <span class="game-player-score">@s.Value</span>
                        </div>
                    </div>
                }
            }
        </aside>

        <main class="game-main">
            <div class="multiplayer-game-card">
                <h1 class="game-page-title">MULTIPLAYER GAME</h1>
                <p class="game-page-subtitle">Lobby code: @Code</p>

                @if (Finished)
                {
                    <div class="multiplayer-game-finish-card">
                        <h2 class="multiplayer-game-finish-title">Game Over</h2>

                        <div class="multiplayer-game-scoreboard">
                            @foreach (var s in Scores.OrderByDescending(x => x.Value))
                            {
                                <div class="multiplayer-game-score-row">
                                    <span class="multiplayer-game-player">@s.Key</span>
                                    <span class="multiplayer-game-points">@s.Value</span>
                                </div>
                            }
                        </div>
                    </div>
                }
                else if (Current == null)
                {
                    <p class="multiplayer-game-message">Waiting for question...</p>
                }
                else
                {
                    @if (ShowingQuestionIntro)
                    {
                        <div class="question-reveal-card">
                            <p class="question-reveal-label">Current Question</p>
                            <h2 class="question-reveal-text">@Current.Question</h2>

                            <div class="question-reveal-progress">
                                <div class="question-reveal-progress-bar"
                                     @key="IntroRenderKey"
                                     style="@($"animation-duration:{CurrentIntroSeconds.ToString("0.00", CultureInfo.InvariantCulture)}s")">
                                </div>
                            </div>
                        </div>
                    }
                    else
                    {
                        <div class="multiplayer-game-question-box">
                            <p class="multiplayer-game-question-label">Current Question</p>
                            <h2 class="multiplayer-game-question">@Current.Question</h2>
                        </div>

                        <p class="multiplayer-game-question-timer">Time left: @TimeLeft s</p>

                        <div class="multiplayer-game-answers">
                            @foreach (var a in Answers)
                            {
                                <button class="multiplayer-game-answer-btn menu-btn @GetAnswerHighlightClass(a)"
                                        style="@GetAnswerStyle(a)"
                                        @onclick="() => Answer(a)"
                                        disabled="@(!CanAnswer)">
                                    <span>@a</span>

                                    @if (GetAnswerMarkers(a).Any())
                                    {
                                        <div class="multiplayer-answer-markers">
                                            @foreach (var marker in GetAnswerMarkers(a))
                                            {
                                                <span class="multiplayer-answer-player-tag @(GetMarkerResultClass(marker))">
                                                    <span class="multiplayer-answer-player-dot" style="background:@marker.PlayerColor;"></span>
                                                    @marker.Username
                                                    @if (marker.PointsAwarded > 0)
                                                    {
                                                        <span> (+@marker.PointsAwarded)</span>
                                                    }
                                                </span>
                                            }
                                        </div>
                                    }
                                </button>
                            }
                        </div>
                    }
                }
            </div>
        </main>
    </div>
</div>

@if (ShowLeaveModal)
{
    <div class="leave-modal-overlay">
        <div class="leave-modal-card">
            <div class="leave-modal-icon">!</div>

            <h2 class="leave-modal-title">Leave game?</h2>

            <p class="leave-modal-text">
                Do you really want to leave the game?
                <br />
                You will be disconnected from the lobby.
            </p>

            <div class="leave-modal-actions">
                <button class="menu-btn leave-modal-btn-secondary" @onclick="CancelLeave">
                    Stay
                </button>

                <button class="menu-btn leave-modal-btn-danger" @onclick="ConfirmLeave">
                    Leave
                </button>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public string Code { get; set; } = "";

    private TriviaQuestion? Current;
    private List<string> Answers = new();
    private bool Locked = false;
    private bool HasAnswered = false;
    private string Message = "";
    private bool Finished = false;
    private string? CorrectAnswer;

    private Dictionary<string, int> Scores = new();
    private List<LivePlayerScoreDto> LiveScores = new();
    private List<QuestionPlayerAnswerDto> RoundResults = new();

    private string? LocalSelectedAnswer;
    private bool ResultsVisible = false;

    private const double QuestionIntroSeconds = 4;
    private double CurrentIntroSeconds = QuestionIntroSeconds;
    private bool ShowingQuestionIntro = false;
    private CancellationTokenSource? IntroCts;
    private int IntroRenderKey = 0;

    private CancellationTokenSource? QuestionTimerCts;
    private int QuestionTimeLimit = 10;
    private int TimeLeft = 10;

    private bool _isLeaving = false;
    private bool ShowLeaveModal = false;
    private string? PendingTargetUrl;

    private bool CanAnswer => !Locked && !ShowingQuestionIntro && !HasAnswered && !Finished && TimeLeft > 0;

    protected override async Task OnInitializedAsync()
    {
        await Mp.ConnectAsync(Nav.BaseUri.TrimEnd('/'));

        Mp.OnNewQuestion += HandleNewQuestion;
        Mp.OnScoresUpdated += HandleScoresUpdated;
        Mp.OnQuestionResolved += HandleQuestionResolved;
        Mp.OnGameFinished += HandleGameFinished;
        Mp.OnGameError += HandleGameError;

        try
        {
            var state = await Mp.GetLobbyStateAsync(Code);
            QuestionTimeLimit = Math.Max(1, state.Settings.TimePerQuestion);

            LiveScores = await Mp.GetLiveScoresAsync(Code);
            var q = await Mp.GetCurrentQuestionAsync(Code);

            if (!LiveScores.Any() && q == null)
            {
                Nav.NavigateTo("/multiplayer", true);
                return;
            }

            if (q != null)
            {
                SetQuestion(q);

                DateTime? startedAtUtc = null;
                try
                {
                    startedAtUtc = await Mp.GetQuestionStartedAtUtcAsync(Code);
                }
                catch
                {
                }

                await StartQuestionIntroAsync(startedAtUtc);
            }
        }
        catch
        {
            Nav.NavigateTo("/multiplayer", true);
        }
    }

    private Task ConfirmLeaveNavigation(LocationChangingContext context)
    {
        if (_isLeaving || Finished)
            return Task.CompletedTask;

        context.PreventNavigation();
        PendingTargetUrl = context.TargetLocation;
        ShowLeaveModal = true;

        return InvokeAsync(StateHasChanged);
    }

    private Task CancelLeave()
    {
        ShowLeaveModal = false;
        PendingTargetUrl = null;
        return InvokeAsync(StateHasChanged);
    }

    private async Task ConfirmLeave()
    {
        if (_isLeaving)
            return;

        _isLeaving = true;
        ShowLeaveModal = false;

        try
        {
            await Mp.LeaveLobbyAsync(Code);
        }
        catch
        {
        }

        var target = PendingTargetUrl;
        PendingTargetUrl = null;

        if (string.IsNullOrWhiteSpace(target))
            await JS.InvokeVoidAsync("appNav.replace", "/multiplayer");
        else
            await JS.InvokeVoidAsync("appNav.replace", target);
    }

    private void HandleNewQuestion(TriviaQuestion q)
    {
        _ = HandleNewQuestionAsync(q);
    }

    private async Task HandleNewQuestionAsync(TriviaQuestion q)
    {
        SetQuestion(q);

        DateTime? startedAtUtc = null;
        try
        {
            startedAtUtc = await Mp.GetQuestionStartedAtUtcAsync(Code);
        }
        catch
        {
        }

        await StartQuestionIntroAsync(startedAtUtc);
    }

    private void HandleScoresUpdated(List<LivePlayerScoreDto> scores)
    {
        LiveScores = scores;
        _ = InvokeAsync(StateHasChanged);
    }

    private void HandleQuestionResolved(QuestionResolutionDto dto)
    {
        QuestionTimerCts?.Cancel();

        Locked = true;
        ResultsVisible = true;
        CorrectAnswer = dto.CorrectAnswer;
        RoundResults = dto.Results ?? new List<QuestionPlayerAnswerDto>();

        var correctCount = RoundResults.Count(x => x.IsCorrect);
        Message = correctCount > 0
            ? $"Correct answer: {dto.CorrectAnswer}"
            : $"Nobody answered. Correct answer: {dto.CorrectAnswer}";

        _ = InvokeAsync(StateHasChanged);
    }

    private void HandleGameFinished(Dictionary<string, int> scores)
    {
        QuestionTimerCts?.Cancel();
        IntroCts?.Cancel();

        Finished = true;
        Scores = scores;
        Locked = true;
        ShowingQuestionIntro = false;

        _ = InvokeAsync(StateHasChanged);
    }

    private void HandleGameError(string msg)
    {
        Message = msg;
        _ = InvokeAsync(StateHasChanged);
    }

    private void SetQuestion(TriviaQuestion q)
    {
        IntroCts?.Cancel();
        QuestionTimerCts?.Cancel();

        Current = q;
        Answers = q.IncorrectAnswers
            .Append(q.CorrectAnswer)
            .OrderBy(_ => Guid.NewGuid())
            .ToList();

        Locked = true;
        HasAnswered = false;
        Message = "";
        CorrectAnswer = null;
        RoundResults = new List<QuestionPlayerAnswerDto>();
        LocalSelectedAnswer = null;
        ResultsVisible = false;
        TimeLeft = QuestionTimeLimit;
    }

    private async Task StartQuestionIntroAsync(DateTime? questionStartedAtUtc)
    {
        IntroCts?.Cancel();
        IntroCts = new CancellationTokenSource();
        var token = IntroCts.Token;

        double remainingSeconds = QuestionIntroSeconds;

        if (questionStartedAtUtc.HasValue)
        {
            var elapsed = (DateTime.UtcNow - questionStartedAtUtc.Value).TotalSeconds;
            remainingSeconds = Math.Max(0, QuestionIntroSeconds - elapsed);
        }

        if (remainingSeconds <= 0.05)
        {
            ShowingQuestionIntro = false;
            Locked = false;
            CurrentIntroSeconds = QuestionIntroSeconds;
            await StartQuestionCountdownAsync(questionStartedAtUtc);
            await InvokeAsync(StateHasChanged);
            return;
        }

        CurrentIntroSeconds = remainingSeconds;
        IntroRenderKey++;
        ShowingQuestionIntro = true;
        Locked = true;
        await InvokeAsync(StateHasChanged);

        try
        {
            await Task.Delay(TimeSpan.FromSeconds(remainingSeconds), token);
        }
        catch (TaskCanceledException)
        {
            return;
        }

        ShowingQuestionIntro = false;
        Locked = false;
        CurrentIntroSeconds = QuestionIntroSeconds;

        await StartQuestionCountdownAsync(questionStartedAtUtc);
        await InvokeAsync(StateHasChanged);
    }

    private Task StartQuestionCountdownAsync(DateTime? questionStartedAtUtc)
    {
        QuestionTimerCts?.Cancel();
        QuestionTimerCts = new CancellationTokenSource();

        var token = QuestionTimerCts.Token;

        _ = Task.Run(async () =>
        {
            try
            {
                while (!token.IsCancellationRequested && !Finished && !ResultsVisible)
                {
                    double remainingSeconds;

                    if (questionStartedAtUtc.HasValue)
                    {
                        var answerStart = questionStartedAtUtc.Value.AddSeconds(QuestionIntroSeconds);
                        var elapsed = (DateTime.UtcNow - answerStart).TotalSeconds;
                        remainingSeconds = Math.Max(0, QuestionTimeLimit - elapsed);
                    }
                    else
                    {
                        remainingSeconds = TimeLeft;
                    }

                    var nextTimeLeft = (int)Math.Ceiling(remainingSeconds);
                    if (nextTimeLeft < 0) nextTimeLeft = 0;

                    if (TimeLeft != nextTimeLeft)
                    {
                        TimeLeft = nextTimeLeft;
                        await InvokeAsync(StateHasChanged);
                    }

                    if (remainingSeconds <= 0)
                    {
                        TimeLeft = 0;
                        Locked = true;
                        await InvokeAsync(StateHasChanged);
                        break;
                    }

                    await Task.Delay(200, token);
                }
            }
            catch (TaskCanceledException)
            {
            }
        }, token);

        return Task.CompletedTask;
    }

    private async Task Answer(string ans)
    {
        if (!CanAnswer) return;

        HasAnswered = true;
        LocalSelectedAnswer = ans;
        await Mp.AnswerQuestionAsync(Code, ans);
        await InvokeAsync(StateHasChanged);
    }

    private IReadOnlyList<QuestionPlayerAnswerDto> GetAnswerMarkers(string answer)
    {
        if (ResultsVisible)
        {
            return RoundResults
                .Where(r => !string.IsNullOrWhiteSpace(r.Answer) &&
                            string.Equals(r.Answer, answer, StringComparison.OrdinalIgnoreCase))
                .ToList();
        }

        if (!string.IsNullOrWhiteSpace(LocalSelectedAnswer) &&
            string.Equals(LocalSelectedAnswer, answer, StringComparison.OrdinalIgnoreCase) &&
            !string.IsNullOrWhiteSpace(Mp.LocalUsername))
        {
            var localColor = LiveScores
                .FirstOrDefault(x => string.Equals(x.Username, Mp.LocalUsername, StringComparison.OrdinalIgnoreCase))
                ?.PlayerColor ?? "#6f5cff";

            return new List<QuestionPlayerAnswerDto>
            {
                new QuestionPlayerAnswerDto
                {
                    Username = Mp.LocalUsername!,
                    PlayerColor = localColor,
                    PointsAwarded = 0
                }
            };
        }

        return Array.Empty<QuestionPlayerAnswerDto>();
    }

    private string GetPlayerColor(string username)
    {
        var live = LiveScores.FirstOrDefault(p =>
            string.Equals(p.Username, username, StringComparison.OrdinalIgnoreCase));

        if (live != null)
            return live.PlayerColor;

        var result = RoundResults.FirstOrDefault(r =>
            string.Equals(r.Username, username, StringComparison.OrdinalIgnoreCase));

        if (result != null)
            return result.PlayerColor;

        return "#6f5cff";
    }

    private string GetAnswerStyle(string answer)
    {
        if (string.IsNullOrWhiteSpace(CorrectAnswer))
            return string.Empty;

        if (string.Equals(answer, CorrectAnswer, StringComparison.OrdinalIgnoreCase))
            return "border:2px solid #51cf66; background:linear-gradient(135deg, rgba(81,207,102,0.38), rgba(81,207,102,0.20));";

        return string.Empty;
    }

    private string GetAnswerHighlightClass(string answer)
        => !string.IsNullOrWhiteSpace(CorrectAnswer) &&
           string.Equals(answer, CorrectAnswer, StringComparison.OrdinalIgnoreCase)
            ? "multiplayer-game-answer-btn--resolved"
            : string.Empty;

    public void Dispose()
    {
        IntroCts?.Cancel();
        QuestionTimerCts?.Cancel();

        Mp.OnNewQuestion -= HandleNewQuestion;
        Mp.OnScoresUpdated -= HandleScoresUpdated;
        Mp.OnQuestionResolved -= HandleQuestionResolved;
        Mp.OnGameFinished -= HandleGameFinished;
        Mp.OnGameError -= HandleGameError;
    }

    private string GetAvatarUrl(string? avatarKey)
    {
        var key = string.IsNullOrWhiteSpace(avatarKey) ? "default" : avatarKey;
        return $"/images/avatars/{key}.png";
    }

    private Task GoHome()
    {
        if (_isLeaving)
            return Task.CompletedTask;

        PendingTargetUrl = "/";
        ShowLeaveModal = true;
        return InvokeAsync(StateHasChanged);
    }
    
    private string GetMarkerResultClass(QuestionPlayerAnswerDto marker)
    {
        if (string.IsNullOrWhiteSpace(marker.Answer))
            return "timeout";

        return marker.IsCorrect ? "correct" : "wrong";
    }
}