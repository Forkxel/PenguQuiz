@page "/multiplayerGame/{Code}"
@using WebQuizGame.Classes.Models
@using WebQuizGame.Classes.Models.Multiplayer
@using WebQuizGame.Classes.Services
@inject MultiplayerClient Mp

<div class="multiplayer-game-page">
    <div class="game-layout">
        <aside class="game-sidebar">
            @if (LiveScores.Any())
            {
                @foreach (var player in LiveScores)
                {
                    <div class="game-player" style="border-left: 4px solid @player.PlayerColor;">
                        <img class="game-avatar"
                             src="@GetAvatarUrl(player.AvatarKey)"
                             alt="avatar" />

                        <div class="game-player-info">
                            <span class="game-player-name">
                                <span class="multiplayer-player-color-dot" style="background:@player.PlayerColor;"></span>
                                @player.Username
                            </span>
                            <span class="game-player-score">@player.Score</span>
                        </div>
                    </div>
                }
            }
            else if (Scores.Any())
            {
                @foreach (var s in Scores.OrderByDescending(x => x.Value))
                {
                    <div class="game-player" style="border-left: 4px solid @GetPlayerColor(s.Key);">
                        <img class="game-avatar"
                             src="@GetAvatarUrl("default_1")"
                             alt="avatar" />

                        <div class="game-player-info">
                            <span class="game-player-name">
                                <span class="multiplayer-player-color-dot" style="background:@GetPlayerColor(s.Key);"></span>
                                @s.Key
                            </span>
                            <span class="game-player-score">@s.Value</span>
                        </div>
                    </div>
                }
            }
        </aside>

        <main class="game-main">
            <div class="multiplayer-game-card">

                <h1 class="game-page-title">Multiplayer Game</h1>
                <p class="game-page-subtitle">Lobby code: @Code</p>

                @if (Finished)
                {
                    <div class="multiplayer-game-finish-card">
                        <h2 class="multiplayer-game-finish-title">Game Over</h2>

                        <div class="multiplayer-game-scoreboard">
                            @foreach (var s in Scores.OrderByDescending(x => x.Value))
                            {
                                <div class="multiplayer-game-score-row">
                                    <span class="multiplayer-game-player">@s.Key</span>
                                    <span class="multiplayer-game-points">@s.Value</span>
                                </div>
                            }
                        </div>
                    </div>
                }
                else if (Current == null)
                {
                    <p class="multiplayer-game-message">Waiting for question...</p>
                }
                else
                {
                    @if (ShowingQuestionIntro)
                    {
                        <div class="question-reveal-card">
                            <p class="question-reveal-label">Current Question</p>
                            <h2 class="question-reveal-text">@Current.Question</h2>

                            <div class="question-reveal-progress">
                                <div class="question-reveal-progress-bar" style="animation-duration:@($"{QuestionIntroSeconds}s")"></div>
                            </div>
                        </div>
                    }
                    else
                    {
                        <div class="multiplayer-game-question-box">
                            <p class="multiplayer-game-question-label">Current Question</p>
                            <h2 class="multiplayer-game-question">@Current.Question</h2>
                        </div>

                        <div class="multiplayer-game-answers">
                            @foreach (var a in Answers)
                            {
                                <button class="multiplayer-game-answer-btn menu-btn @GetAnswerHighlightClass(a)"
                                        style="@GetAnswerStyle(a)"
                                        @onclick="() => Answer(a)"
                                        disabled="@Locked">
                                    @a
                                    @if (ResolvedAnswer == a && !string.IsNullOrWhiteSpace(ResolvedBy))
                                    {
                                        <span class="multiplayer-answer-player-tag">@ResolvedBy</span>
                                    }
                                </button>
                            }
                        </div>

                        @if (!string.IsNullOrWhiteSpace(Message))
                        {
                            <div class="multiplayer-game-info-box">
                                <p class="multiplayer-game-message">@Message</p>
                            </div>
                        }
                    }
                }
            </div>
        </main>
    </div>
</div>

@code {
    [Parameter] public string Code { get; set; } = "";

    private TriviaQuestion? Current;
    private List<string> Answers = new();
    private bool Locked = false;
    private string Message = "";
    private bool Finished = false;
    private string? ResolvedAnswer;
    private string? ResolvedBy;

    private Dictionary<string, int> Scores = new();
    private List<LivePlayerScoreDto> LiveScores = new();

    private const int QuestionIntroSeconds = 4;
    private bool ShowingQuestionIntro = false;
    private double IntroProgressPercent = 100;
    private CancellationTokenSource? IntroCts;

    protected override async Task OnInitializedAsync()
    {
        await Mp.ConnectAsync("http://localhost:5237");

        Mp.OnNewQuestion += q =>
        {
            SetQuestion(q);
            _ = StartQuestionIntroAsync();
        };

        Mp.OnScoresUpdated += scores =>
        {
            LiveScores = scores;
            InvokeAsync(StateHasChanged);
        };

        Mp.OnQuestionWon += winner =>
        {
            Locked = true;
            Message = $"{winner} answered correctly!";
            InvokeAsync(StateHasChanged);
        };

        Mp.OnQuestionResolved += (who, chosen, correct) =>
        {
            Locked = true;
            ResolvedAnswer = who == "TIMEOUT" ? null : chosen;
            ResolvedBy = who == "TIMEOUT" ? null : who;
            Message = who == "TIMEOUT"
                ? "Time's up! Nobody answered."
                : $"{who} clicked \"{chosen}\" -> {(correct ? "CORRECT" : "WRONG")}";
            InvokeAsync(StateHasChanged);
        };

        Mp.OnGameFinished += scores =>
        {
            Finished = true;
            Scores = scores;
            InvokeAsync(StateHasChanged);
        };

        LiveScores = await Mp.GetLiveScoresAsync(Code);

        var q = await Mp.GetCurrentQuestionAsync(Code);
        if (q != null)
        {
            SetQuestion(q);
            await StartQuestionIntroAsync();
        }
    }

    private void SetQuestion(TriviaQuestion q)
    {
        Current = q;
        Answers = q.IncorrectAnswers
            .Append(q.CorrectAnswer)
            .OrderBy(_ => Guid.NewGuid())
            .ToList();

        Locked = true;
        Message = "";
        ResolvedAnswer = null;
        ResolvedBy = null;
    }

    private async Task StartQuestionIntroAsync()
    {
        IntroCts?.Cancel();
        IntroCts = new CancellationTokenSource();
        var token = IntroCts.Token;

        ShowingQuestionIntro = true;
        IntroProgressPercent = 100;
        Locked = true;
        await InvokeAsync(StateHasChanged);

        var started = DateTime.UtcNow;
        var totalMs = QuestionIntroSeconds * 1000.0;

        try
        {
            while (!token.IsCancellationRequested)
            {
                var elapsed = (DateTime.UtcNow - started).TotalMilliseconds;
                var ratio = Math.Clamp(elapsed / totalMs, 0, 1);
                IntroProgressPercent = 100 - (ratio * 100);

                await InvokeAsync(StateHasChanged);

                if (ratio >= 1)
                    break;

                await Task.Delay(50, token);
            }
        }
        catch (TaskCanceledException)
        {
            return;
        }

        ShowingQuestionIntro = false;
        Locked = false;
        await InvokeAsync(StateHasChanged);
    }

    private string GetPlayerColor(string username)
    {
        var live = LiveScores.FirstOrDefault(p => string.Equals(p.Username, username, StringComparison.OrdinalIgnoreCase));
        if (live != null) return live.PlayerColor;

        return "#6f5cff";
    }

    private string GetAnswerStyle(string answer)
    {
        if (ResolvedAnswer != answer || string.IsNullOrWhiteSpace(ResolvedBy))
            return string.Empty;

        var color = GetPlayerColor(ResolvedBy);
        return $"background:{color}; border-color:{color}; color:#101323;";
    }

    private string GetAnswerHighlightClass(string answer)
        => ResolvedAnswer == answer && !string.IsNullOrWhiteSpace(ResolvedBy)
            ? "multiplayer-game-answer-btn--resolved"
            : string.Empty;

    private async Task Answer(string ans)
    {
        if (Locked || ShowingQuestionIntro) return;
        Locked = true;
        await Mp.AnswerQuestionAsync(Code, ans);
    }

    private string GetAvatarUrl(string? avatarKey)
    {
        var key = string.IsNullOrWhiteSpace(avatarKey) ? "default_1" : avatarKey;
        return $"/images/avatars/{key}.png";
    }
}