@page "/profileMenu"
@using System.Net.Http.Headers
@using WebQuizGame.Classes.Models
@inject Authorization Auth
@inject NavigationManager Navigation
@inject HttpClient Http

<div class="profile-menu-page">
    <div class="profile-menu-screen">
        <h1 class="profile-menu-title">Profile</h1>
        <p class="profile-menu-subtitle">Your ranked statistics and account overview</p>

        @if (!Auth.IsLoggedIn)
        {
            <div class="profile-menu-card">
                <p class="profile-menu-message">You are not logged in.</p>
            </div>
        }
        else if (Profile == null && string.IsNullOrWhiteSpace(Message))
        {
            <div class="profile-menu-card">
                <p class="profile-menu-message">Loading profile...</p>
            </div>
        }
        else if (Profile != null)
        {
            <div class="profile-menu-card">
                <div class="profile-menu-user-box">
                    <div class="profile-menu-avatar-wrap">
                        <img class="profile-menu-avatar"
                             src="@GetAvatarUrl(Profile.AvatarKey)"
                             alt="avatar" />
                    </div>

                    <span class="profile-menu-user-label">Username</span>
                    <span class="profile-menu-user-value">@Profile.Username</span>
                </div>

                <div class="profile-menu-section">
                    <h2 class="profile-menu-section-title">Single Ranked</h2>

                    <div class="profile-menu-stats">
                        <div class="profile-menu-stat-box">
                            <span class="profile-menu-stat-label">Elo</span>
                            <span class="profile-menu-stat-value">@Profile.SingleElo</span>
                        </div>

                        <div class="profile-menu-stat-box">
                            <span class="profile-menu-stat-label">Played</span>
                            <span class="profile-menu-stat-value">@Profile.SingleRankedPlayed</span>
                        </div>

                        <div class="profile-menu-stat-box">
                            <span class="profile-menu-stat-label">Wins</span>
                            <span class="profile-menu-stat-value">@Profile.SingleRankedWins</span>
                        </div>
                    </div>
                </div>

                <div class="profile-menu-section">
                    <h2 class="profile-menu-section-title">Multiplayer Ranked</h2>

                    <div class="profile-menu-stats">
                        <div class="profile-menu-stat-box">
                            <span class="profile-menu-stat-label">Elo</span>
                            <span class="profile-menu-stat-value">@Profile.MultiElo</span>
                        </div>

                        <div class="profile-menu-stat-box">
                            <span class="profile-menu-stat-label">Played</span>
                            <span class="profile-menu-stat-value">@Profile.MultiRankedPlayed</span>
                        </div>

                        <div class="profile-menu-stat-box">
                            <span class="profile-menu-stat-label">Wins</span>
                            <span class="profile-menu-stat-value">@Profile.MultiRankedWins</span>
                        </div>
                    </div>
                </div>

                <div class="profile-menu-actions">
                    <button class="profile-menu-btn" @onclick="GoToSettings">
                        Account Settings
                    </button>
                    <button class="profile-menu-btn profile-menu-btn-secondary" @onclick="GoBackToMenu">
                        Back to Menu
                    </button>

                    <button class="profile-menu-btn profile-menu-btn-danger" @onclick="Logout">
                        Logout
                    </button>
                </div>
            </div>
        }

        @if (!string.IsNullOrWhiteSpace(Message))
        {
            <div class="profile-menu-error-box">
                <p class="profile-menu-message">@Message</p>
            </div>
        }
    </div>
</div>

@code {
    private RankedProfileResponse? Profile;
    private string Message = "";

    protected override async Task OnInitializedAsync()
    {
        await Auth.InitializeAsync();

        if (!Auth.IsLoggedIn)
        {
            Navigation.NavigateTo("/profile");
            return;
        }

        var token = await Auth.GetTokenAsync();
        if (string.IsNullOrWhiteSpace(token))
        {
            Message = "Missing token.";
            return;
        }

        Http.DefaultRequestHeaders.Authorization =
            new AuthenticationHeaderValue("Bearer", token);

        var response = await Http.GetAsync("api/ranked/profile");

        if (!response.IsSuccessStatusCode)
        {
            var errorText = await response.Content.ReadAsStringAsync();
            Message = $"Failed to load profile: {response.StatusCode} - {errorText}";
            return;
        }

        Profile = await response.Content.ReadFromJsonAsync<RankedProfileResponse>();

        if (Profile == null)
            Message = "Profile response was empty.";
    }

    private void GoBackToMenu()
    {
        Navigation.NavigateTo("/");
    }

    private async Task Logout()
    {
        await Auth.Logout();
        Navigation.NavigateTo("/", true);
    }
    
    private void GoToSettings()
    {
        Navigation.NavigateTo("/accountSettings");
    }
    
    private string GetAvatarUrl(string? avatarKey)
    {
        var key = string.IsNullOrWhiteSpace(avatarKey) ? "default" : avatarKey;
        return $"/images/avatars/{key}.png";
    }
}