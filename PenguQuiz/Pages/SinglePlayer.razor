@page "/singleplayer"
@using WebQuizGame.Classes.Models
@inject NavigationManager Navigation
@inject HttpClient Http
@using Microsoft.AspNetCore.Components.Routing
@inject IJSRuntime JS
@inject Authorization Auth

<NavigationLock OnBeforeInternalNavigation="ConfirmLeaveNavigation" />

<div class="single-game-page">
    <button class="home-floating-btn home-with-text" @onclick="GoHome" title="Home">
        <img src="/images/avatars/macaroni.png" alt="Home" class="home-floating-img" />
        <span>Home</span>
    </button>
    <div class="single-game-layout">
        <aside class="single-game-sidebar">
            <div class="single-game-sidebar-avatar-wrap">
                <img class="single-game-sidebar-avatar"
                     src="@GetMyAvatarUrl()"
                     alt="avatar"/>
            </div>

            <div class="single-game-sidebar-name">@GetDisplayName()</div>

            <div class="single-game-sidebar-stat">
                <span class="single-game-sidebar-stat-label">Score</span>
                <span class="single-game-sidebar-stat-value">@Score</span>
            </div>

            @if (Questions.Count > 0 && CurrentQuestionIndex < Questions.Count)
            {
                <div class="single-game-sidebar-stat">
                    <span class="single-game-sidebar-stat-label">Question</span>
                    <span class="single-game-sidebar-stat-value">@(CurrentQuestionIndex + 1) / @Questions.Count</span>
                </div>
            }

            @if (time > 0)
            {
                <div class="single-game-sidebar-stat">
                    <span class="single-game-sidebar-stat-label">Time</span>
                    <span class="single-game-sidebar-stat-value">@TimeLeft s</span>
                </div>
            }
        </aside>

        <div class="single-game-screen">
            <h1 class="single-game-title">Quiz Game</h1>
            <p class="single-game-subtitle">Answer the questions as fast as you can</p>

            @if (Questions == null || Questions.Count == 0)
            {
                <div class="single-game-card">
                    <p class="single-game-message">Loading questions...</p>
                </div>
            }
            else if (CurrentQuestionIndex < Questions.Count)
            {
                <div class="single-game-topbar">
                    <div class="single-game-stat">
                        <span class="single-game-stat-label">Score</span>
                        <span class="single-game-stat-value">@Score</span>
                    </div>

                    @if (time > 0)
                    {
                        <div class="single-game-stat">
                            <span class="single-game-stat-label">Time Left</span>
                            <span class="single-game-stat-value">@TimeLeft s</span>
                        </div>
                    }
                </div>

                <div class="single-game-card">
                    @if (ShowingQuestionIntro)
                    {
                        <div class="question-reveal-card">
                            <p class="question-reveal-label">Question @(CurrentQuestionIndex + 1)</p>
                            <h2 class="question-reveal-text">
                                @Questions[CurrentQuestionIndex]?.Text
                            </h2>

                            <div class="question-reveal-progress">
                                <div class="question-reveal-progress-bar" style="animation-duration:@($"{QuestionIntroSeconds}s")"></div>
                            </div>
                        </div>
                    }
                    else
                    {
                        <div class="single-game-question-box">
                            <p class="single-game-question-number">Question @(CurrentQuestionIndex + 1)</p>
                            <p class="single-game-question-text">
                                @Questions[CurrentQuestionIndex]?.Text
                            </p>
                        </div>

                        <div class="single-game-answers">
                            @if (Questions[CurrentQuestionIndex]?.Type == "boolean")
                            {
                                <button disabled="@Answered"
                                        class="answer-btn single-game-answer-btn @GetAnswerClass("True")"
                                        @onclick="CheckTrue">
                                    True
                                </button>

                                <button disabled="@Answered"
                                        class="answer-btn single-game-answer-btn @GetAnswerClass("False")"
                                        @onclick="CheckFalse">
                                    False
                                </button>
                            }
                            else
                            {
                                @foreach (var ans in Questions[CurrentQuestionIndex]?.Answers ?? new())
                                {
                                    <button disabled="@Answered"
                                            class="answer-btn single-game-answer-btn @GetAnswerClass(ans)"
                                            @onclick="() => CheckAnswer(ans)">
                                        @ans
                                    </button>
                                }
                            }
                        </div>
                    }
                </div>
            }
            else
            {
                <div class="single-game-card single-game-finish-card">
                    <h2 class="single-game-finish-title">Quiz Finished!</h2>

                    <div class="single-game-summary">
                        <div class="single-game-summary-box">
                            <span class="single-game-summary-label">Total Score</span>
                            <span class="single-game-summary-value">@Score</span>
                        </div>

                        <div class="single-game-summary-box">
                            <span class="single-game-summary-label">Correct Answers</span>
                            <span class="single-game-summary-value">@AnswerRecords.Count(a => a.IsCorrect)</span>
                        </div>

                        <div class="single-game-summary-box">
                            <span class="single-game-summary-label">Total Questions</span>
                            <span class="single-game-summary-value">@Questions.Count</span>
                        </div>

                        @if (AnswerRecords.Count > 0)
                        {
                            var timed = AnswerRecords.Where(a => a.TimeTaken > 0).ToList();

                            if (timed.Any())
                            {
                                <div class="single-game-summary-box">
                                    <span class="single-game-summary-label">Average Time</span>
                                    <span class="single-game-summary-value">@Math.Round(timed.Average(a => a.TimeTaken), 2) s</span>
                                </div>

                                <div class="single-game-summary-box">
                                    <span class="single-game-summary-label">Total Time</span>
                                    <span class="single-game-summary-value">@Math.Round(timed.Sum(a => a.TimeTaken), 2) s</span>
                                </div>
                            }
                        }
                    </div>

                    <div class="single-game-actions">
                        <button class="menu-btn single-game-menu-btn" @onclick="RestartGame">Restart Game</button>
                        <button class="menu-btn single-game-menu-btn single-game-secondary-btn" @onclick="GoToMenu">Singleplayer Menu</button>
                    </div>
                </div>
            }
        </div>
    </div>
</div>

@if (ShowLeaveModal)
{
    <div class="leave-modal-overlay">
        <div class="leave-modal-card">
            <div class="leave-modal-icon">!</div>

            <h2 class="leave-modal-title">Leave singleplayer game?</h2>

            <p class="leave-modal-text">
                Do you really want to leave the game?
                <br />
                Your current progress will be lost.
            </p>

            <div class="leave-modal-actions">
                <button class="menu-btn leave-modal-btn-secondary" @onclick="CancelLeave">
                    Stay
                </button>

                <button class="menu-btn leave-modal-btn-danger" @onclick="ConfirmLeave">
                    Leave
                </button>
            </div>
        </div>
    </div>
}

@code {

    [Parameter, SupplyParameterFromQuery] public string? categories { get; set; }
    [Parameter, SupplyParameterFromQuery] public string? difficulty { get; set; }
    [Parameter, SupplyParameterFromQuery] public int amount { get; set; }
    [Parameter, SupplyParameterFromQuery] public int time { get; set; }

    private List<Question> Questions = new();
    private int CurrentQuestionIndex = 0;
    private int Score = 0;
    private bool Answered = false;
    private string? SelectedAnswer;
    private bool ForceFreshOnNextLoad = false;

    private int TimeLeft;
    private CancellationTokenSource? TimerCts;

    private const int QuestionIntroSeconds = 4;
    private bool ShowingQuestionIntro = false;
    private double IntroProgressPercent = 100;
    private CancellationTokenSource? IntroCts;

    private List<AnswerRecord> AnswerRecords = new();

    private DateTime? QuestionStartTime;
    private bool IsLoadingQuestions = false;
    
    private bool _isLeaving = false;
    private bool ShowLeaveModal = false;
    private string? PendingTargetUrl;
    
    private bool IsGameFinished => Questions.Count > 0 && CurrentQuestionIndex >= Questions.Count;

    private bool IsGameInProgress =>
        Questions.Count > 0 &&
        CurrentQuestionIndex < Questions.Count &&
        !IsLoadingQuestions;

    protected override async Task OnInitializedAsync()
    {
        await LoadQuestionsAsync();
        await Auth.InitializeAsync();

        if (Questions.Count > 0)
            await StartQuestionIntroAsync();
    }
    
    private Task ConfirmLeaveNavigation(LocationChangingContext context)
    {
        if (_isLeaving || IsGameFinished || !IsGameInProgress)
            return Task.CompletedTask;

        var target = Navigation.ToBaseRelativePath(context.TargetLocation).ToLowerInvariant();

        if (target.StartsWith("singleplayer?", StringComparison.OrdinalIgnoreCase))
            return Task.CompletedTask;

        context.PreventNavigation();
        PendingTargetUrl = context.TargetLocation;
        ShowLeaveModal = true;

        InvokeAsync(StateHasChanged);
        return Task.CompletedTask;
    }

    private Task CancelLeave()
    {
        ShowLeaveModal = false;
        PendingTargetUrl = null;
        return InvokeAsync(StateHasChanged);
    }

    private async Task ConfirmLeave()
    {
        if (_isLeaving)
            return;

        _isLeaving = true;
        ShowLeaveModal = false;

        TimerCts?.Cancel();
        IntroCts?.Cancel();

        var target = PendingTargetUrl;
        PendingTargetUrl = null;

        if (string.IsNullOrWhiteSpace(target))
            await JS.InvokeVoidAsync("appNav.replace", "/singleplayerMenu");
        else
            await JS.InvokeVoidAsync("appNav.replace", target);
    }

    private async Task LoadQuestionsAsync()
    {
        if (IsLoadingQuestions) return;
        IsLoadingQuestions = true;

        Questions = new();
        
        var query = new List<string>
        {
            $"amount={amount}"
        };

        if (!string.IsNullOrWhiteSpace(difficulty))
            query.Add($"difficulty={difficulty}");

        if (!string.IsNullOrWhiteSpace(categories))
            query.Add($"categories={categories}");

        if (ForceFreshOnNextLoad)
        {
            query.Add("fresh=true");
            ForceFreshOnNextLoad = false;
        }

        var url = "api/trivia?" + string.Join("&", query);

        var response = await Http.GetAsync(url);
        if (!response.IsSuccessStatusCode)
        {
            IsLoadingQuestions = false;
            return;
        }

        var data = await response.Content.ReadFromJsonAsync<TriviaResponse>();

        if (data?.Results != null && data.Results.Count > 0)
            Questions.AddRange(ParseTrivia(data));

        Questions = Questions.OrderBy(_ => Guid.NewGuid()).ToList();

        IsLoadingQuestions = false;
        StateHasChanged();
    }

    private async Task StartQuestionIntroAsync()
    {
        TimerCts?.Cancel();
        IntroCts?.Cancel();

        IntroCts = new CancellationTokenSource();
        var token = IntroCts.Token;

        ShowingQuestionIntro = true;
        IntroProgressPercent = 100;
        TimeLeft = time;
        QuestionStartTime = null;

        await InvokeAsync(StateHasChanged);

        var started = DateTime.UtcNow;
        var totalMs = QuestionIntroSeconds * 1000.0;

        try
        {
            while (!token.IsCancellationRequested)
            {
                var elapsed = (DateTime.UtcNow - started).TotalMilliseconds;
                var ratio = Math.Clamp(elapsed / totalMs, 0, 1);
                IntroProgressPercent = 100 - (ratio * 100);

                await InvokeAsync(StateHasChanged);

                if (ratio >= 1)
                    break;

                await Task.Delay(50, token);
            }
        }
        catch (TaskCanceledException)
        {
            return;
        }

        ShowingQuestionIntro = false;
        StartQuestionTimer();
        await InvokeAsync(StateHasChanged);
    }

    private async Task CheckAnswer(string selected)
    {
        if (Answered || CurrentQuestionIndex >= Questions.Count || ShowingQuestionIntro)
        {
            return;
        }

        Answered = true;
        SelectedAnswer = selected;

        TimerCts?.Cancel();

        double timeTaken = 0;

        if (QuestionStartTime.HasValue && time > 0)
        {
            timeTaken = (DateTime.UtcNow - QuestionStartTime.Value).TotalSeconds;
        }

        var q = Questions[CurrentQuestionIndex];

        AnswerRecords.Add(new AnswerRecord
        {
            Question = q,
            IsCorrect = selected == q.CorrectAnswer,
            TimeTaken = timeTaken
        });

        if (selected == q.CorrectAnswer)
        {
            Score += 10;
        }

        StateHasChanged();

        await Task.Delay(800);

        Answered = false;
        SelectedAnswer = null;
        CurrentQuestionIndex++;

        if (CurrentQuestionIndex < Questions.Count)
        {
            await StartQuestionIntroAsync();
        }

        StateHasChanged();
    }

    private void CheckTrue() => _ = CheckAnswer("True");
    private void CheckFalse() => _ = CheckAnswer("False");

    private void StartQuestionTimer()
    {
        QuestionStartTime = DateTime.UtcNow;

        if (time <= 0) return;

        TimerCts?.Cancel();
        TimerCts = new CancellationTokenSource();

        TimeLeft = time;

        _ = RunTimer(TimerCts.Token);
    }

    private async Task RunTimer(CancellationToken token)
    {
        try
        {
            while (TimeLeft > 0 && !token.IsCancellationRequested)
            {
                await Task.Delay(1000, token);
                TimeLeft--;
                StateHasChanged();
            }

            if (TimeLeft == 0 && !Answered && !ShowingQuestionIntro)
                await CheckAnswer("TIMEOUT");
        }
        catch { }
    }

    private string GetAnswerClass(string answer)
    {
        if (!Answered || CurrentQuestionIndex >= Questions.Count)
            return "";

        var correct = Questions[CurrentQuestionIndex].CorrectAnswer;

        if (answer == correct) return "correct";
        if (answer == SelectedAnswer) return "wrong";

        return "disabled";
    }

    private async Task RestartGame()
    {
        _isLeaving = true;

        TimerCts?.Cancel();
        TimerCts = null;
        IntroCts?.Cancel();
        IntroCts = null;

        Questions = new();
        AnswerRecords = new();
        CurrentQuestionIndex = 0;
        Score = 0;
        SelectedAnswer = null;
        Answered = false;
        ShowingQuestionIntro = false;
        IntroProgressPercent = 100;

        ForceFreshOnNextLoad = true;

        await LoadQuestionsAsync();

        if (Questions.Count > 0)
            await StartQuestionIntroAsync();

        _isLeaving = false;
    }

    private async Task GoToMenu()
    {
        if (IsGameFinished)
        {
            await JS.InvokeVoidAsync("appNav.replace", "/singleplayerMenu");
            return;
        }

        if (!IsGameInProgress)
        {
            await JS.InvokeVoidAsync("appNav.replace", "/singleplayerMenu");
            return;
        }

        PendingTargetUrl = "/singleplayerMenu";
        ShowLeaveModal = true;
        await InvokeAsync(StateHasChanged);
    }

    private List<Question> ParseTrivia(TriviaResponse response)
    {
        return response.Results.Select(r => new Question
        {
            Text = System.Net.WebUtility.HtmlDecode(r.Question),
            CorrectAnswer = System.Net.WebUtility.HtmlDecode(r.CorrectAnswer),
            Type = r.Type,
            Answers = r.Type == "multiple"
                ? r.IncorrectAnswers
                    .Select(a => System.Net.WebUtility.HtmlDecode(a))
                    .Append(System.Net.WebUtility.HtmlDecode(r.CorrectAnswer))
                    .OrderBy(_ => Guid.NewGuid())
                    .ToList()
                : new List<string> { "True", "False" }
        }).ToList();
    }
    
    private string GetMyAvatarUrl()
    {
        var key = string.IsNullOrWhiteSpace(Auth.AvatarKey) ? "default" : Auth.AvatarKey;
        return $"/images/avatars/{key}.png";
    }
    
    private string GetDisplayName()
    {
        return string.IsNullOrWhiteSpace(Auth.Username) ? "Guest" : Auth.Username!;
    }
    
    private Task GoHome()
    {
        if (_isLeaving)
            return Task.CompletedTask;

        PendingTargetUrl = "/";
        ShowLeaveModal = true;
        return InvokeAsync(StateHasChanged);
    }
}