@page "/lobby/{Code}"
@using WebQuizGame.Classes.Models
@using WebQuizGame.Classes.Models.Multiplayer
@using WebQuizGame.Classes.Services
@inject MultiplayerClient Mp
@inject Authorization Auth
@inject NavigationManager Nav
@implements IDisposable

<div class="lobby-page">
    <div class="lobby-screen">
        <h1 class="lobby-title">Lobby @Code</h1>
        <p class="lobby-subtitle">Prepare your match and wait for the game to start</p>

        @if (State == null)
        {
            <div class="lobby-card">
                <p class="lobby-message">Loading lobby...</p>
            </div>
        }
        else
        {
            <div class="lobby-card">
                <div class="lobby-overview">
                    <div class="lobby-overview-box">
                        <span class="lobby-overview-label">Host</span>
                        <span class="lobby-overview-value">@State.HostUsername</span>
                    </div>

                    <div class="lobby-overview-box">
                        <span class="lobby-overview-label">Players</span>

                        <div class="lobby-overview-value lobby-player-list">
                            @foreach (var player in State.PlayerDetails)
                            {
                                <div class="lobby-player-row">
                                    <img class="lobby-player-avatar"
                                         src="@GetAvatarUrl(player.AvatarKey)"
                                         alt="avatar" />

                                    <span class="lobby-player-name">@player.Username</span>
                                </div>
                            }
                        </div>
                    </div>
                </div>

                @if (!string.IsNullOrWhiteSpace(GameError))
                {
                    <div class="lobby-error-box">
                        <p class="lobby-message"><strong>@GameError</strong></p>
                    </div>
                }

                <div class="lobby-section">
                    <h2 class="lobby-section-title">Settings</h2>

                    <div class="lobby-settings-grid">
                        <div class="lobby-setting-box">
                            <span class="lobby-setting-label">Questions</span>
                            <span class="lobby-setting-value">@State.Settings.Amount</span>
                        </div>

                        <div class="lobby-setting-box">
                            <span class="lobby-setting-label">Time per Question</span>
                            <span class="lobby-setting-value">@(State.Settings.TimePerQuestion == 0 ? "∞" : $"{State.Settings.TimePerQuestion}s")</span>
                        </div>

                        <div class="lobby-setting-box">
                            <span class="lobby-setting-label">Difficulty</span>
                            <span class="lobby-setting-value">@State.Settings.Difficulty</span>
                        </div>

                        <div class="lobby-setting-box lobby-setting-box-wide">
                            <span class="lobby-setting-label">Categories</span>
                            <span class="lobby-setting-value">@(State.Settings.CategoryIds.Count == 0 ? "Any" : string.Join(", ", State.Settings.CategoryIds))</span>
                        </div>
                    </div>
                </div>

                @if (IsHost)
                {
                    <div class="lobby-section lobby-host-section">
                        <h2 class="lobby-section-title">Host Settings</h2>

                        <div class="lobby-form-grid">
                            <div class="lobby-field">
                                <label class="lobby-label">Amount</label>
                                <input class="lobby-input" type="number" min="5" max="50" @bind="Amount" />
                            </div>

                            <div class="lobby-field">
                                <label class="lobby-label">Time</label>
                                <select class="lobby-select" @bind="TimePerQuestion">
                                    <option value="5">5</option>
                                    <option value="10">10</option>
                                    <option value="15">15</option>
                                    <option value="30">30</option>
                                    <option value="0">Infinite</option>
                                </select>
                            </div>

                            <div class="lobby-field">
                                <label class="lobby-label">Difficulty</label>
                                <select class="lobby-select" @bind="Difficulty">
                                    <option value="any">Any</option>
                                    <option value="easy">Easy</option>
                                    <option value="medium">Medium</option>
                                    <option value="hard">Hard</option>
                                </select>
                            </div>
                        </div>

                        <div class="lobby-field">
                            <p class="lobby-label">Categories (max 3)</p>
                            <div class="lobby-categories">
                                @foreach (var cat in Categories)
                                {
                                    <label class="lobby-check-item">
                                        <input type="checkbox"
                                               @onchange="() => ToggleCategory(cat.Id)"
                                               checked="@SelectedCategoryIds.Contains(cat.Id)"
                                               disabled="@(!SelectedCategoryIds.Contains(cat.Id) && SelectedCategoryIds.Count >= 3)" />
                                        <span>@cat.Name</span>
                                    </label>
                                }
                            </div>
                        </div>

                        <div class="lobby-actions">
                            <button class="menu-btn lobby-action-btn" @onclick="ApplySettings">Apply</button>

                            <button class="menu-btn lobby-action-btn lobby-start-btn"
                                    @onclick="StartGame"
                                    disabled="@(State.Players.Count < 2)">
                                Start (min 2 players)
                            </button>
                        </div>
                    </div>
                }

                @if (State != null && State.IsMatchmaking && State.MatchmakingEndsAtUtc != null)
                {
                    <div class="lobby-status-box">
                        <p class="lobby-message"><strong>Matchmaking in progress...</strong></p>
                        <p class="lobby-message">
                            Game starts in
                            @Math.Max(0, (int)(State.MatchmakingEndsAtUtc.Value - DateTime.UtcNow).TotalSeconds)
                            seconds.
                        </p>
                    </div>
                }

                @if (State.IsStarted)
                {
                    <div class="lobby-status-box">
                        <p class="lobby-message"><strong>Game started!</strong></p>
                    </div>
                }
            </div>
        }
    </div>
</div>

@code {
    [Parameter] public string Code { get; set; } = "";

    private LobbyState? State;

    private int Amount = 10;
    private int TimePerQuestion = 10;
    private string Difficulty = "any";
    private List<int> SelectedCategoryIds = new();
    private bool _navigated = false;
    private PeriodicTimer? _timer;
    private string? GameError;

    private bool IsHost => State != null && State.HostUsername == Mp.LocalUsername;

    protected override async Task OnInitializedAsync()
    {
        await Auth.InitializeAsync();
        await Mp.ConnectAsync("http://localhost:5237");
        
        _timer = new PeriodicTimer(TimeSpan.FromSeconds(1));

        _ = Task.Run(async () =>
        {
            while (await _timer.WaitForNextTickAsync())
            {
                await InvokeAsync(StateHasChanged);
            }
        });
        
        Mp.OnLobbyUpdated += s =>
        {
            if (s.Code == Code)
            {
                State = s;

                Amount = s.Settings.Amount;
                TimePerQuestion = s.Settings.TimePerQuestion;
                Difficulty = s.Settings.Difficulty;
                SelectedCategoryIds = s.Settings.CategoryIds.ToList();

                if (State.IsStarted && !_navigated)
                {
                    _navigated = true;
                    Nav.NavigateTo($"/multiplayerGame/{Code}");
                    return;
                }

                InvokeAsync(StateHasChanged);
            }
        };
        
        Mp.OnGameError += msg =>
        {
            GameError = msg;
            InvokeAsync(StateHasChanged);
        };

        Mp.OnNewQuestion += async q =>
        {
            if (_navigated) return;
            _navigated = true;
            await Task.Delay(100);
            Nav.NavigateTo($"/multiplayerGame/{Code}");
        };
        
        State = await Mp.GetLobbyStateAsync(Code);
        Amount = State.Settings.Amount;
        TimePerQuestion = State.Settings.TimePerQuestion;
        Difficulty = State.Settings.Difficulty;
        SelectedCategoryIds = State.Settings.CategoryIds.ToList();
    }

    private async Task ApplySettings()
    {
        var settings = new LobbySettings(Amount, TimePerQuestion, Difficulty, SelectedCategoryIds.ToList());
        await Mp.UpdateSettingsAsync(Code, settings);
    }

    private async Task StartGame()
    {
        await Mp.StartGameAsync(Code);
    }

    private void ToggleCategory(int id)
    {
        if (SelectedCategoryIds.Contains(id)) SelectedCategoryIds.Remove(id);
        else SelectedCategoryIds.Add(id);
    }

    private List<Category> Categories = new()
    {
        new Category { Id = 9,  Name = "General Knowledge" },
        new Category { Id = 17, Name = "Science & Nature" },
        new Category { Id = 18, Name = "Science: Computers" },
        new Category { Id = 21, Name = "Sports" },
        new Category { Id = 22, Name = "Geography" },
        new Category { Id = 23, Name = "History" },
        new Category { Id = 24, Name = "Politics" },
        new Category { Id = 27, Name = "Animals" },
        new Category { Id = 32, Name = "Cartoon & Animations" }
    };

    public void Dispose()
    {
        _timer?.Dispose();
    }
    
    private string GetAvatarUrl(string? avatarKey)
    {
        var key = string.IsNullOrWhiteSpace(avatarKey) ? "default_1" : avatarKey;
        return $"/images/avatars/{key}.png";
    }
}