@page "/multiplayer"
@using WebQuizGame.Classes.Models
@using WebQuizGame.Classes.Models.Multiplayer
@using WebQuizGame.Classes.Services
@inject MultiplayerClient Mp
@inject Authorization Auth
@inject NavigationManager Nav
@inject CustomQuizMultiplayerClient CustomMp

<div class="multiplayer-page">
    <div class="multiplayer-screen">
        <h1 class="multiplayer-title">Multiplayer</h1>
        <p class="multiplayer-subtitle">Choose how you want to play online</p>

        @if (!Auth.IsLoggedIn)
        {
            <div class="multiplayer-info-box">
                <p class="multiplayer-message">
                    For multiplayer, it is recommended to be logged in so your username is used. Otherwise, "Guest" will be used.
                </p>
            </div>
        }

        <div class="multiplayer-main-actions">
            <button class="menu-btn" @onclick="QuickMatchAny">Quick Match (Any)</button>
            <button class="menu-btn" @onclick="GoToCustomCreate">Create Custom Lobby</button>
            <button class="menu-btn" @onclick="GoToRanked">Ranked Multiplayer</button>
            <button class="menu-btn" @onclick="GoToSavedQuizLibrary">My Saved Quiz Lobbies</button>
        </div>

        <div class="multiplayer-join-card">
            <h2 class="multiplayer-join-title">Join Custom Lobby</h2>

            <div class="multiplayer-join-form">
                <input class="multiplayer-input" placeholder="Lobby code" @bind="JoinCode" />
                <button class="menu-btn multiplayer-join-btn" @onclick="JoinLobby">Join</button>
            </div>
        </div>

        @if (!string.IsNullOrWhiteSpace(Message))
        {
            <div class="multiplayer-info-box multiplayer-error-box">
                <p class="multiplayer-message">@Message</p>
            </div>
        }
    </div>
</div>

@code {
    private string JoinCode = "";
    private string Message = "";

    protected override async Task OnInitializedAsync()
    {
        await Auth.InitializeAsync();
        await Mp.ConnectAsync(Nav.BaseUri.TrimEnd('/'));
    }

    private string GetUsername()
    {
        if (!string.IsNullOrWhiteSpace(Auth.Username))
            return Auth.Username!;

        return "Guest_" + Guid.NewGuid().ToString("N").Substring(0, 4);
    }

    private async Task QuickMatchAny()
    {
        Message = "";

        var prefs = new LobbySettings(10, 10, "any", new List<int> { 9 });

        var state = await Mp.QuickMatchAsync(
            new QuickMatchRequest(
                GetUsername(),
                prefs,
                2,
                4,
                Auth.AvatarKey ?? "default"));

        Nav.NavigateTo($"/lobby/{state.Code}");
    }

    private void GoToCustomCreate()
    {
        Nav.NavigateTo("/multiplayerCustomCreate");
    }

    private void GoToRanked()
    {
        Nav.NavigateTo("/multiplayerRanked");
    }

    private async Task JoinLobby()
    {
        Message = "";

        if (string.IsNullOrWhiteSpace(JoinCode))
        {
            Message = "Enter a lobby code";
            return;
        }

        var code = JoinCode.Trim().ToUpper();
        var username = GetUsername();
        var avatar = Auth.AvatarKey ?? "default";
        
        try
        {
            await CustomMp.ConnectAsync(Nav.BaseUri.TrimEnd('/'));

            var state = await CustomMp.JoinLobbyAsync(
                new JoinCustomQuizMultiplayerLobbyRequest(code, username, avatar));

            Nav.NavigateTo($"/multiplayerSavedQuizLobby/{state.Code}");
            return;
        }
        catch
        {
        }
        
        try
        {
            var state = await Mp.JoinLobbyAsync(
                new JoinLobbyRequest(code, username, avatar));

            Nav.NavigateTo($"/lobby/{state.Code}");
            return;
        }
        catch
        {
            Message = "Lobby not found";
        }
    }
    
    private void GoToSavedQuizLibrary()
    {
        Nav.NavigateTo("/multiplayerCustomQuizLibrary");
    }
}