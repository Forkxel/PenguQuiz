@page "/singleplayerRanked"
@using WebQuizGame.Classes.Models
@inject NavigationManager Navigation
@inject HttpClient Http
@inject Authorization Auth
@using System.Net.Http.Headers
@using Microsoft.AspNetCore.Components.Routing
@inject IJSRuntime JS

<NavigationLock OnBeforeInternalNavigation="ConfirmLeaveNavigation" />

<div class="ranked-game-page">
    <button class="home-floating-btn home-with-text" @onclick="GoHome" title="Home">
        <img src="/images/avatars/macaroni.png" alt="Home" class="home-floating-img" />
        <span>Home</span>
    </button>
    <div class="ranked-game-layout">
        <aside class="ranked-game-sidebar">
            <div class="ranked-game-sidebar-avatar-wrap">
                <img class="ranked-game-sidebar-avatar"
                     src="@GetMyAvatarUrl()"
                     alt="avatar"/>
            </div>

            <div class="ranked-game-sidebar-name">@Auth.Username</div>

            <div class="ranked-game-sidebar-stat">
                <span class="ranked-game-sidebar-stat-label">Score</span>
                <span class="ranked-game-sidebar-stat-value">@Score</span>
            </div>

            <div class="ranked-game-sidebar-stat">
                <span class="ranked-game-sidebar-stat-label">Correct</span>
                <span class="ranked-game-sidebar-stat-value">@CorrectAnswers</span>
            </div>

            @if (Questions != null && Questions.Count > 0 && CurrentQuestionIndex < Questions.Count)
            {
                <div class="ranked-game-sidebar-stat">
                    <span class="ranked-game-sidebar-stat-label">Question</span>
                    <span class="ranked-game-sidebar-stat-value">@(CurrentQuestionIndex + 1) / @Questions.Count</span>
                </div>
            }
            
            @if (Questions != null && Questions.Count > 0 && CurrentQuestionIndex < Questions.Count && !ShowingQuestionIntro)
            {
                <div class="ranked-game-sidebar-stat">
                    <span class="ranked-game-sidebar-stat-label">Time</span>
                    <span class="ranked-game-sidebar-stat-value">@TimeLeft s</span>
                </div>
            }
        </aside>

        <div class="ranked-game-screen">
            <h1 class="ranked-game-title">Ranked Quiz</h1>
            <p class="ranked-game-subtitle">Play for rating and answer as fast as possible</p>

            @if (Questions == null || Questions.Count == 0)
            {
                <div class="ranked-game-card">
                    <p class="ranked-game-message">Loading questions...</p>
                </div>
            }
            else if (CurrentQuestionIndex < Questions.Count)
            {
                <div class="ranked-game-card">
                    @if (ShowingQuestionIntro)
                    {
                        <div class="question-reveal-card">
                            <p class="question-reveal-label">Question @(@CurrentQuestionIndex + 1)</p>
                            <h2 class="question-reveal-text">@Questions[CurrentQuestionIndex].Text</h2>

                            <div class="question-reveal-progress">
                                <div class="question-reveal-progress-bar" style="animation-duration:@($"{QuestionIntroSeconds}s")"></div>
                            </div>
                        </div>
                    }
                    else
                    {
                        <div class="ranked-game-question-box">
                            <p class="ranked-game-question-number">Question @(@CurrentQuestionIndex + 1)</p>
                            <p class="ranked-game-question-text">@Questions[CurrentQuestionIndex].Text</p>
                        </div>

                        <div class="ranked-game-answers">
                            @if (Questions[CurrentQuestionIndex].Type == "boolean")
                            {
                                <button class="answer-btn ranked-game-answer-btn @GetAnswerClass("True")"
                                        disabled="@Answered"
                                        @onclick="CheckTrue">
                                    True
                                </button>

                                <button class="answer-btn ranked-game-answer-btn @GetAnswerClass("False")"
                                        disabled="@Answered"
                                        @onclick="CheckFalse">
                                    False
                                </button>
                            }
                            else
                            {
                                @foreach (var ans in Questions[CurrentQuestionIndex].Answers)
                                {
                                    <button class="answer-btn ranked-game-answer-btn @GetAnswerClass(ans)"
                                            disabled="@Answered"
                                            @onclick="() => CheckAnswer(ans)">
                                        @ans
                                    </button>
                                }
                            }
                        </div>
                    }
                </div>
            }
            else
            {
                <div class="ranked-game-card ranked-game-finish-card">
                    <h2 class="ranked-game-finish-title">Ranked Finished</h2>

                    <div class="ranked-game-summary">
                        <div class="ranked-game-summary-box">
                            <span class="ranked-game-summary-label">Total Score</span>
                            <span class="ranked-game-summary-value">@Score</span>
                        </div>

                        <div class="ranked-game-summary-box">
                            <span class="ranked-game-summary-label">Correct Answers</span>
                            <span class="ranked-game-summary-value">@CorrectAnswers</span>
                        </div>

                        <div class="ranked-game-summary-box">
                            <span class="ranked-game-summary-label">Total Questions</span>
                            <span class="ranked-game-summary-value">15</span>
                        </div>

                        @if (RankedResult != null)
                        {
                            <div class="ranked-game-summary-box">
                                <span class="ranked-game-summary-label">Old Rating</span>
                                <span class="ranked-game-summary-value">@RankedResult.OldRating</span>
                            </div>

                            <div class="ranked-game-summary-box">
                                <span class="ranked-game-summary-label">New Rating</span>
                                <span class="ranked-game-summary-value">@RankedResult.NewRating</span>
                            </div>

                            <div class="ranked-game-summary-box">
                                <span class="ranked-game-summary-label">Rating Change</span>
                                <span class="ranked-game-summary-value">@(RankedResult.Delta >= 0 ? "+" : "")@RankedResult.Delta</span>
                            </div>
                        }
                    </div>

                    <div class="ranked-game-actions">
                        <button class="menu-btn ranked-game-menu-btn" @onclick="RestartGame">Play Again</button>
                        <button class="menu-btn ranked-game-menu-btn ranked-game-secondary-btn" @onclick="GoToMenu">Menu</button>
                    </div>
                </div>
            }
        </div>
    </div>
</div>

@if (ShowLeaveModal)
{
    <div class="leave-modal-overlay">
        <div class="leave-modal-card">
            <div class="leave-modal-icon">!</div>

            <h2 class="leave-modal-title">Leave ranked singleplayer?</h2>

            <p class="leave-modal-text">
                Do you really want to leave the ranked game?
                <br />
                Your current ranked run will be lost.
            </p>

            <div class="leave-modal-actions">
                <button class="menu-btn leave-modal-btn-secondary" @onclick="CancelLeave">
                    Stay
                </button>

                <button class="menu-btn leave-modal-btn-danger" @onclick="ConfirmLeave">
                    Leave
                </button>
            </div>
        </div>
    </div>
}

@code {
    private const int Amount = 15;
    private const int TimePerQuestion = 15;
    private const int QuestionIntroSeconds = 4;

    private List<Question>? Questions;
    private int CurrentQuestionIndex = 0;
    private int Score = 0;
    private int CorrectAnswers = 0;
    private string? SelectedAnswer;
    private bool Answered = false;
    private int TimeLeft;
    private CancellationTokenSource? TimerCts;
    private DateTime QuestionStartTime;
    private double TotalAnswerTimeSeconds = 0;
    private RankedSubmitResponse? RankedResult;
    private bool RankedSubmitted = false;
    private bool _isLeaving = false;
    private bool ShowLeaveModal = false;
    private string? PendingTargetUrl;

    private bool ShowingQuestionIntro = false;
    private double IntroProgressPercent = 100;
    private CancellationTokenSource? IntroCts;
    
    private bool IsGameFinished => Questions != null && Questions.Count > 0 && CurrentQuestionIndex >= Questions.Count;

    private bool IsGameInProgress =>
        Questions != null &&
        Questions.Count > 0 &&
        CurrentQuestionIndex < Questions.Count;

    protected override async Task OnInitializedAsync()
    {
        await Auth.InitializeAsync();

        if (!Auth.IsLoggedIn)
        {
            Navigation.NavigateTo("/profile", true);
            return;
        }

        Questions = new List<Question>();
        await LoadQuestions();

        if (Questions.Count > 0)
            await StartQuestionIntroAsync();
    }
    
    private Task ConfirmLeaveNavigation(LocationChangingContext context)
    {
        if (_isLeaving || IsGameFinished || !IsGameInProgress)
            return Task.CompletedTask;

        var target = Navigation.ToBaseRelativePath(context.TargetLocation).ToLowerInvariant();

        if (target == "singleplayerranked")
            return Task.CompletedTask;

        context.PreventNavigation();
        PendingTargetUrl = context.TargetLocation;
        ShowLeaveModal = true;

        InvokeAsync(StateHasChanged);
        return Task.CompletedTask;
    }

    private Task CancelLeave()
    {
        ShowLeaveModal = false;
        PendingTargetUrl = null;
        return InvokeAsync(StateHasChanged);
    }

    private async Task ConfirmLeave()
    {
        if (_isLeaving)
            return;

        _isLeaving = true;
        ShowLeaveModal = false;

        TimerCts?.Cancel();
        IntroCts?.Cancel();
        
        try
        {
            var token = await Auth.GetTokenAsync();

            if (!string.IsNullOrWhiteSpace(token))
            {
                Http.DefaultRequestHeaders.Authorization =
                    new AuthenticationHeaderValue("Bearer", token);

                await Http.PostAsync("api/ranked/single/forfeit", null);
            }
        }
        catch { }

        var target = PendingTargetUrl;
        PendingTargetUrl = null;

        if (string.IsNullOrWhiteSpace(target))
            await JS.InvokeVoidAsync("appNav.replace", "/singleplayerMenu");
        else
            await JS.InvokeVoidAsync("appNav.replace", target);
    }

    private async Task LoadQuestions()
    {
        var url = $"api/trivia?amount={Amount}&difficulty=any&fresh=true";

        var response = await Http.GetAsync(url);
        if (!response.IsSuccessStatusCode) return;

        var data = await response.Content.ReadFromJsonAsync<TriviaResponse>();

        if (data?.Results != null)
            Questions = ParseTrivia(data);
    }

    private async Task StartQuestionIntroAsync()
    {
        TimerCts?.Cancel();
        IntroCts?.Cancel();

        IntroCts = new CancellationTokenSource();
        var token = IntroCts.Token;

        ShowingQuestionIntro = true;
        IntroProgressPercent = 100;
        TimeLeft = TimePerQuestion;

        await InvokeAsync(StateHasChanged);

        var started = DateTime.UtcNow;
        var totalMs = QuestionIntroSeconds * 1000.0;

        try
        {
            while (!token.IsCancellationRequested)
            {
                var elapsed = (DateTime.UtcNow - started).TotalMilliseconds;
                var ratio = Math.Clamp(elapsed / totalMs, 0, 1);
                IntroProgressPercent = 100 - (ratio * 100);

                await InvokeAsync(StateHasChanged);

                if (ratio >= 1)
                    break;

                await Task.Delay(50, token);
            }
        }
        catch (TaskCanceledException)
        {
            return;
        }

        ShowingQuestionIntro = false;
        StartTimer();
        await InvokeAsync(StateHasChanged);
    }

    private async Task CheckAnswer(string selected)
    {
        if (Answered || Questions == null || ShowingQuestionIntro) return;

        Answered = true;
        SelectedAnswer = selected;

        TimerCts?.Cancel();

        var current = Questions[CurrentQuestionIndex];
        var answerTime = (DateTime.UtcNow - QuestionStartTime).TotalSeconds;
        TotalAnswerTimeSeconds += answerTime;

        if (selected == current.CorrectAnswer)
        {
            int timeBonus = Math.Max(0, TimePerQuestion - (int)Math.Floor(answerTime));
            Score += 10 + timeBonus;
            CorrectAnswers++;
        }

        StateHasChanged();
        await Task.Delay(600);

        SelectedAnswer = null;
        Answered = false;
        CurrentQuestionIndex++;

        if (CurrentQuestionIndex < Questions.Count)
        {
            await StartQuestionIntroAsync();
        }
        else
        {
            await SubmitRankedResult();
        }

        StateHasChanged();
    }

    private void StartTimer()
    {
        TimerCts?.Cancel();
        TimerCts = new CancellationTokenSource();

        TimeLeft = TimePerQuestion;
        QuestionStartTime = DateTime.UtcNow;

        _ = RunTimer(TimerCts.Token);
    }

    private async Task RunTimer(CancellationToken token)
    {
        try
        {
            while (TimeLeft > 0 && !token.IsCancellationRequested)
            {
                await Task.Delay(1000, token);
                TimeLeft--;
                await InvokeAsync(StateHasChanged);
            }
        }
        catch
        {
            return;
        }

        if (TimeLeft == 0 && !Answered && !ShowingQuestionIntro)
        {
            await CheckAnswer("TIMEOUT");
        }
    }

    private List<Question> ParseTrivia(TriviaResponse response)
    {
        return response.Results.Select(r => new Question
        {
            Text = System.Net.WebUtility.HtmlDecode(r.Question),
            CorrectAnswer = System.Net.WebUtility.HtmlDecode(r.CorrectAnswer),
            Type = r.Type,
            Answers = r.Type == "multiple"
                ? r.IncorrectAnswers
                    .Select(a => System.Net.WebUtility.HtmlDecode(a))
                    .Append(System.Net.WebUtility.HtmlDecode(r.CorrectAnswer))
                    .OrderBy(_ => Guid.NewGuid())
                    .ToList()
                : new List<string> { "True", "False" }
        }).ToList();
    }

    private string GetAnswerClass(string answer)
    {
        if (!Answered || Questions == null) return "";

        var correct = Questions[CurrentQuestionIndex].CorrectAnswer;

        if (answer == correct)
            return "correct";

        if (answer == SelectedAnswer)
            return "wrong";

        return "disabled";
    }

    private void CheckTrue() => _ = CheckAnswer("True");
    private void CheckFalse() => _ = CheckAnswer("False");

    private async Task RestartGame()
    {
        _isLeaving = true;

        TimerCts?.Cancel();
        IntroCts?.Cancel();

        Questions = new List<Question>();
        CurrentQuestionIndex = 0;
        Score = 0;
        CorrectAnswers = 0;
        SelectedAnswer = null;
        Answered = false;
        TimeLeft = TimePerQuestion;
        TotalAnswerTimeSeconds = 0;
        RankedResult = null;
        RankedSubmitted = false;
        ShowingQuestionIntro = false;
        IntroProgressPercent = 100;

        await LoadQuestions();

        if (Questions.Count > 0)
            await StartQuestionIntroAsync();

        _isLeaving = false;
    }

    private async Task GoToMenu()
    {
        if (IsGameFinished || !IsGameInProgress)
        {
            await JS.InvokeVoidAsync("appNav.replace", "/singleplayerMenu");
            return;
        }

        PendingTargetUrl = "/singleplayerMenu";
        ShowLeaveModal = true;
        await InvokeAsync(StateHasChanged);
    }
    
    private async Task SubmitRankedResult()
    {
        if (RankedSubmitted) return;

        var token = await Auth.GetTokenAsync();
        if (string.IsNullOrWhiteSpace(token)) return;
        
        Http.DefaultRequestHeaders.Authorization =
            new AuthenticationHeaderValue("Bearer", token);

        double averageTime = Questions == null || Questions.Count == 0
            ? 0
            : TotalAnswerTimeSeconds / Questions.Count;

        var request = new SubmitSingleRankedRequest
        {
            Score = Score,
            CorrectAnswers = CorrectAnswers,
            TotalQuestions = Questions?.Count ?? 0,
            AverageTimeSeconds = averageTime,
            Difficulty = "any"
        };

        var response = await Http.PostAsJsonAsync(
            "api/ranked/single/submit",
            request);

        if (!response.IsSuccessStatusCode)
            return;

        RankedResult = await response.Content.ReadFromJsonAsync<RankedSubmitResponse>();
        RankedSubmitted = true;
    }
    
    private string GetMyAvatarUrl()
    {
        var key = string.IsNullOrWhiteSpace(Auth.AvatarKey) ? "default" : Auth.AvatarKey;
        return $"/images/avatars/{key}.png";
    }
    
    private Task GoHome()
    {
        if (_isLeaving)
            return Task.CompletedTask;

        PendingTargetUrl = "/";
        ShowLeaveModal = true;
        return InvokeAsync(StateHasChanged);
    }
}