@page "/multiplayerRanked"
@using WebQuizGame.Classes.Models
@using WebQuizGame.Classes.Services
@inject Authorization Auth
@inject RankedMultiplayerClient RankedMp
@inject NavigationManager Nav

<div class="ranked-multi-page">
    <div class="ranked-multi-screen">
        <h1 class="ranked-multi-title">Ranked Multiplayer</h1>
        <p class="ranked-multi-subtitle">Queue up for a fast 1v1 ranked match</p>

        <div class="ranked-multi-card">
            @if (!Auth.IsLoggedIn)
            {
                <div class="ranked-multi-info-box">
                    <p class="ranked-multi-message">
                        You must be logged in to play Ranked Multiplayer.
                    </p>
                </div>

                <div class="ranked-multi-actions">
                    <button class="menu-btn ranked-multi-btn" @onclick="GoLogin">Login</button>
                </div>
            }
            else
            {
                <div class="ranked-multi-info-box">
                    <h2 class="ranked-multi-section-title">Match Rules</h2>

                    <div class="ranked-multi-rules">
                        <div class="ranked-multi-rule-box">
                            <span class="ranked-multi-rule-label">Mode</span>
                            <span class="ranked-multi-rule-value">1v1 Quick Match</span>
                        </div>

                        <div class="ranked-multi-rule-box">
                            <span class="ranked-multi-rule-label">Questions</span>
                            <span class="ranked-multi-rule-value">15</span>
                        </div>

                        <div class="ranked-multi-rule-box">
                            <span class="ranked-multi-rule-label">Time</span>
                            <span class="ranked-multi-rule-value">15 s</span>
                        </div>

                        <div class="ranked-multi-rule-box">
                            <span class="ranked-multi-rule-label">Difficulty</span>
                            <span class="ranked-multi-rule-value">Any</span>
                        </div>
                    </div>
                </div>

                <div class="ranked-multi-actions">
                    <button class="menu-btn ranked-multi-btn"
                            @onclick="FindMatch"
                            disabled="@Searching">
                        @(Searching ? "Searching..." : "Find Ranked Match")
                    </button>
                </div>

                @if (!string.IsNullOrWhiteSpace(Message))
                {
                    <div class="ranked-multi-status-box">
                        <p class="ranked-multi-message">@Message</p>
                    </div>
                }
            }
        </div>
    </div>
</div>

@code {
    private bool Searching = false;
    private string Message = "";

    protected override async Task OnInitializedAsync()
    {
        await Auth.InitializeAsync();
    }

    private void GoLogin()
    {
        Nav.NavigateTo("/profile", true);
    }

    private async Task FindMatch()
    {
        if (!Auth.IsLoggedIn)
        {
            Nav.NavigateTo("/profile", true);
            return;
        }

        var token = await Auth.GetTokenAsync();
        if (string.IsNullOrWhiteSpace(token))
        {
            Message = "Missing authentication token.";
            return;
        }

        Searching = true;
        Message = "";

        await RankedMp.ConnectAsync("http://localhost:5237", token);
        var state = await RankedMp.QuickMatchRankedAsync();

        Nav.NavigateTo($"/rankedLobby/{state.Code}");
    }
}