@page "/rankedMultiplayerGame/{Code}"
@using WebQuizGame.Classes.Models
@using WebQuizGame.Classes.Models.Multiplayer.MultiplayerRanked
@using WebQuizGame.Classes.Services
@using LivePlayerScoreDto = WebQuizGame.Classes.Models.Multiplayer.MultiplayerRanked.LivePlayerScoreDto
@inject RankedMultiplayerClient RankedMp
@inject Authorization Auth
@inject NavigationManager Nav
@implements IDisposable

<div class="ranked-mp-game-page">
    <div class="ranked-mp-game-layout">

        <aside class="ranked-mp-game-sidebar">
            @if (LiveScores.Any())
            {
                @foreach (var player in LiveScores)
                {
                    <div class="ranked-mp-game-player-card" style="border-left:4px solid @player.PlayerColor;">
                        <img class="ranked-mp-game-player-avatar"
                             src="@GetAvatarUrl(player.AvatarKey)"
                             alt="avatar" />

                        <div class="ranked-mp-game-player-meta">
                            <span class="ranked-mp-game-player-name">
                                <span class="multiplayer-player-color-dot" style="background:@player.PlayerColor;"></span>
                                @player.Username
                            </span>
                            <span class="ranked-mp-game-player-score">@player.Score</span>
                        </div>
                    </div>
                }
            }
        </aside>

        <main class="ranked-mp-game-main">
            <div class="ranked-mp-game-card">

                <h1 class="ranked-mp-game-title">Ranked Multiplayer</h1>
                <p class="ranked-mp-game-subtitle">Lobby code: @Code</p>

                @if (Finished && FinalResult != null)
                {
                    <div class="ranked-mp-game-finish-card">
                        <h2 class="ranked-mp-game-finish-title">Match Finished</h2>

                        <div class="ranked-mp-game-result-list">
                            @foreach (var r in FinalResult.Results.OrderBy(x => x.Place).ThenBy(x => x.Username))
                            {
                                <div class="ranked-mp-game-result-item">
                                    <div class="ranked-mp-game-result-header-row">
                                        <img class="ranked-mp-game-result-avatar"
                                             src="@GetAvatarUrl(r.AvatarKey)"
                                             alt="avatar" />

                                        <span class="ranked-mp-game-result-name">
                                            #@r.Place - @r.Username @(r.IsWinner ? "(Winner)" : "")
                                        </span>
                                    </div>

                                    <div class="ranked-mp-game-result-stats">
                                        <div class="ranked-mp-game-result-box">
                                            <span class="ranked-mp-game-result-label">Score</span>
                                            <span class="ranked-mp-game-result-value">@r.Score</span>
                                        </div>

                                        <div class="ranked-mp-game-result-box">
                                            <span class="ranked-mp-game-result-label">Old Rating</span>
                                            <span class="ranked-mp-game-result-value">@r.OldRating</span>
                                        </div>

                                        <div class="ranked-mp-game-result-box">
                                            <span class="ranked-mp-game-result-label">New Rating</span>
                                            <span class="ranked-mp-game-result-value">@r.NewRating</span>
                                        </div>

                                        <div class="ranked-mp-game-result-box">
                                            <span class="ranked-mp-game-result-label">Change</span>
                                            <span class="ranked-mp-game-result-value">
                                                @(r.Delta >= 0 ? "+" : "")@r.Delta
                                            </span>
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>

                        <div class="ranked-mp-game-actions">
                            <button class="menu-btn ranked-mp-game-menu-btn" @onclick="BackToMenu">Back</button>
                        </div>
                    </div>
                }
                else if (Current == null)
                {
                    <p class="ranked-mp-game-message">Waiting for question...</p>
                }
                else
                {
                    @if (ShowingQuestionIntro)
                    {
                        <div class="question-reveal-card">
                            <p class="question-reveal-label">Current Question</p>
                            <h2 class="question-reveal-text">@Current.Question</h2>

                            <div class="question-reveal-progress">
                                <div class="question-reveal-progress-bar" style="animation-duration:@($"{QuestionIntroSeconds}s")"></div>
                            </div>
                        </div>
                    }
                    else
                    {
                        <div class="ranked-mp-game-question-box">
                            <p class="ranked-mp-game-question-label">Current Question</p>
                            <h2 class="ranked-mp-game-question">@Current.Question</h2>
                        </div>

                        <div class="ranked-mp-game-answers">
                            @foreach (var a in Answers)
                            {
                                <button class="menu-btn ranked-mp-game-answer-btn @GetAnswerHighlightClass(a)"
                                        style="@GetAnswerStyle(a)"
                                        @onclick="() => Answer(a)"
                                        disabled="@(!CanAnswer)">
                                    <span>@a</span>

                                    @if (GetAnswerMarkers(a).Any())
                                    {
                                        <div style="display:flex; flex-wrap:wrap; gap:6px; margin-top:10px; justify-content:center;">
                                            @foreach (var marker in GetAnswerMarkers(a))
                                            {
                                                <span style="background:@marker.PlayerColor; color:#101323; padding:4px 8px; border-radius:999px; font-size:12px; font-weight:700;">
                                                    @marker.Username
                                                    @if (marker.PointsAwarded > 0)
                                                    {
                                                        <span> (+@marker.PointsAwarded)</span>
                                                    }
                                                </span>
                                            }
                                        </div>
                                    }
                                </button>
                            }
                        </div>
                    }
                }

            </div>
        </main>

    </div>
</div>

@code {
    [Parameter] public string Code { get; set; } = "";

    private TriviaQuestion? Current;
    private List<string> Answers = new();
    private bool Locked = false;
    private bool HasAnswered = false;
    private string Message = "";
    private bool Finished = false;
    private RankedGameFinishedDto? FinalResult;
    private List<LivePlayerScoreDto> LiveScores = new();
    private List<RankedQuestionPlayerAnswerDto> RoundResults = new();
    private string? CorrectAnswer;

    private string? LocalSelectedAnswer;
    private bool ResultsVisible = false;

    private const int QuestionIntroSeconds = 4;
    private bool ShowingQuestionIntro = false;
    private CancellationTokenSource? IntroCts;

    private bool CanAnswer => !Locked && !ShowingQuestionIntro && !HasAnswered && !Finished;

    protected override async Task OnInitializedAsync()
    {
        await Auth.InitializeAsync();

        if (!Auth.IsLoggedIn)
        {
            Nav.NavigateTo("/profile", true);
            return;
        }

        var token = await Auth.GetTokenAsync();
        if (string.IsNullOrWhiteSpace(token))
        {
            Nav.NavigateTo("/profile", true);
            return;
        }

        await RankedMp.ConnectAsync("http://localhost:5237", token);

        RankedMp.OnNewQuestion += HandleNewQuestion;
        RankedMp.OnQuestionResolved += HandleQuestionResolved;
        RankedMp.OnGameFinished += HandleGameFinished;
        RankedMp.OnGameError += HandleGameError;
        RankedMp.OnScoresUpdated += HandleScoresUpdated;

        LiveScores = await RankedMp.GetLiveScoresAsync(Code);

        var q = await RankedMp.GetCurrentRankedQuestionAsync(Code);
        if (q != null)
        {
            SetQuestion(q);
            await StartQuestionIntroAsync();
        }
    }

    private void HandleNewQuestion(TriviaQuestion q)
    {
        SetQuestion(q);
        _ = StartQuestionIntroAsync();
    }

    private void SetQuestion(TriviaQuestion q)
    {
        Current = q;
        Answers = q.IncorrectAnswers
            .Append(q.CorrectAnswer)
            .OrderBy(_ => Guid.NewGuid())
            .ToList();

        Locked = true;
        HasAnswered = false;
        Message = "";
        CorrectAnswer = null;
        RoundResults = new List<RankedQuestionPlayerAnswerDto>();
        LocalSelectedAnswer = null;
        ResultsVisible = false;
    }

    private async Task StartQuestionIntroAsync()
    {
        IntroCts?.Cancel();
        IntroCts = new CancellationTokenSource();
        var token = IntroCts.Token;

        ShowingQuestionIntro = true;
        Locked = true;
        await InvokeAsync(StateHasChanged);

        try
        {
            await Task.Delay(TimeSpan.FromSeconds(QuestionIntroSeconds), token);
        }
        catch (TaskCanceledException)
        {
            return;
        }

        ShowingQuestionIntro = false;
        Locked = false;
        await InvokeAsync(StateHasChanged);
    }

    private void HandleQuestionResolved(RankedQuestionResolutionDto dto)
    {
        Locked = true;
        ResultsVisible = true;
        CorrectAnswer = dto.CorrectAnswer;
        RoundResults = dto.Results ?? new List<RankedQuestionPlayerAnswerDto>();

        var correctCount = RoundResults.Count(x => x.IsCorrect);
        Message = correctCount > 0
            ? $"Správná odpověď: {dto.CorrectAnswer}"
            : $"Nikdo neodpověděl správně. Správná odpověď: {dto.CorrectAnswer}";

        _ = InvokeAsync(StateHasChanged);
    }

    private void HandleGameFinished(RankedGameFinishedDto dto)
    {
        if (dto.LobbyCode != Code) return;

        Finished = true;
        FinalResult = dto;
        Locked = true;

        _ = InvokeAsync(StateHasChanged);
    }

    private void HandleGameError(string msg)
    {
        Message = msg;
        _ = InvokeAsync(StateHasChanged);
    }

    private async Task Answer(string ans)
    {
        if (!CanAnswer) return;

        HasAnswered = true;
        LocalSelectedAnswer = ans;
        await RankedMp.AnswerRankedQuestionAsync(Code, ans);
        await InvokeAsync(StateHasChanged);
    }

    private void BackToMenu()
    {
        Nav.NavigateTo("/multiplayerRanked");
    }

    public void Dispose()
    {
        IntroCts?.Cancel();

        RankedMp.OnNewQuestion -= HandleNewQuestion;
        RankedMp.OnQuestionResolved -= HandleQuestionResolved;
        RankedMp.OnGameFinished -= HandleGameFinished;
        RankedMp.OnGameError -= HandleGameError;
        RankedMp.OnScoresUpdated -= HandleScoresUpdated;
    }

    private string GetAvatarUrl(string? avatarKey)
    {
        var key = string.IsNullOrWhiteSpace(avatarKey) ? "default_1" : avatarKey;
        return $"/images/avatars/{key}.png";
    }

    private void HandleScoresUpdated(List<LivePlayerScoreDto> scores)
    {
        LiveScores = scores;
        _ = InvokeAsync(StateHasChanged);
    }

    private IReadOnlyList<RankedQuestionPlayerAnswerDto> GetAnswerMarkers(string answer)
    {
        if (ResultsVisible)
        {
            return RoundResults
                .Where(r => !string.IsNullOrWhiteSpace(r.Answer) &&
                            string.Equals(r.Answer, answer, StringComparison.OrdinalIgnoreCase))
                .ToList();
        }

        if (!string.IsNullOrWhiteSpace(LocalSelectedAnswer) &&
            string.Equals(LocalSelectedAnswer, answer, StringComparison.OrdinalIgnoreCase) &&
            !string.IsNullOrWhiteSpace(Auth.Username))
        {
            var localColor = LiveScores
                .FirstOrDefault(x => string.Equals(x.Username, Auth.Username, StringComparison.OrdinalIgnoreCase))
                ?.PlayerColor ?? "#6f5cff";

            return new List<RankedQuestionPlayerAnswerDto>
            {
                new RankedQuestionPlayerAnswerDto
                {
                    Username = Auth.Username!,
                    PlayerColor = localColor,
                    PointsAwarded = 0
                }
            };
        }

        return Array.Empty<RankedQuestionPlayerAnswerDto>();
    }

    private string GetAnswerStyle(string answer)
    {
        if (string.IsNullOrWhiteSpace(CorrectAnswer))
            return string.Empty;

        if (string.Equals(answer, CorrectAnswer, StringComparison.OrdinalIgnoreCase))
            return "border:2px solid #51cf66; background:linear-gradient(135deg, rgba(81,207,102,0.38), rgba(81,207,102,0.20));";

        return string.Empty;
    }

    private string GetAnswerHighlightClass(string answer)
        => !string.IsNullOrWhiteSpace(CorrectAnswer) &&
           string.Equals(answer, CorrectAnswer, StringComparison.OrdinalIgnoreCase)
            ? "multiplayer-game-answer-btn--resolved"
            : string.Empty;
}