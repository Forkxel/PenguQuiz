@page "/rankedLobby/{Code}"
@using WebQuizGame.Classes.Models
@using WebQuizGame.Classes.Models.Multiplayer.MultiplayerRanked
@using WebQuizGame.Classes.Services
@using Microsoft.AspNetCore.Components.Routing
@inject RankedMultiplayerClient RankedMp
@inject Authorization Auth
@inject NavigationManager Nav
@inject IJSRuntime JS
@implements IDisposable

<NavigationLock OnBeforeInternalNavigation="ConfirmLeaveNavigation" />

<div class="ranked-lobby-page">
    <button class="home-floating-btn home-with-text" @onclick="GoHome" title="Home">
        <img src="/images/avatars/macaroni.png" alt="Home" class="home-floating-img" />
        <span>Home</span>
    </button>
    <div class="ranked-lobby-screen">
        <h1 class="ranked-lobby-title">Ranked Lobby</h1>
        <p class="ranked-lobby-subtitle">Preparing your ranked 1v1 match</p>

        <div class="ranked-lobby-card">
            @if (State == null)
            {
                <div class="ranked-lobby-status-box">
                    <p class="ranked-lobby-message">Loading lobby...</p>
                </div>
            }
            else
            {
                <div class="ranked-lobby-overview">
                    <div class="ranked-lobby-overview-box">
                        <span class="ranked-lobby-overview-label">Lobby Code</span>
                        <span class="ranked-lobby-overview-value">@Code</span>
                    </div>

                    <div class="ranked-lobby-overview-box">
                        <span class="ranked-lobby-overview-label">Mode</span>
                        <span class="ranked-lobby-overview-value">Ranked 1v1</span>
                    </div>
                </div>

                <div class="ranked-lobby-section">
                    <h2 class="ranked-lobby-section-title">Players</h2>
                    <div class="ranked-lobby-players-box">
                        <div class="ranked-lobby-players-list">
                            @foreach (var player in State.PlayerDetails)
                            {
                                <div class="ranked-lobby-player-item ranked-lobby-player-row">
                                    <div class="ranked-lobby-player-avatar-wrap">
                                        <img class="ranked-lobby-player-avatar"
                                             src="@GetAvatarUrl(player.AvatarKey)"
                                             alt="avatar"/>
                                    </div>

                                    <span class="ranked-lobby-player-name">@player.Username</span>
                                </div>
                            }
                        </div>
                    </div>
                </div>

                <div class="ranked-lobby-section">
                    <h2 class="ranked-lobby-section-title">Match Settings</h2>
                    <div class="ranked-lobby-settings-grid">
                        <div class="ranked-lobby-setting-box">
                            <span class="ranked-lobby-setting-label">Questions</span>
                            <span class="ranked-lobby-setting-value">@State.Settings.Amount</span>
                        </div>

                        <div class="ranked-lobby-setting-box">
                            <span class="ranked-lobby-setting-label">Time per question</span>
                            <span class="ranked-lobby-setting-value">@State.Settings.TimePerQuestion s</span>
                        </div>

                        <div class="ranked-lobby-setting-box">
                            <span class="ranked-lobby-setting-label">Difficulty</span>
                            <span class="ranked-lobby-setting-value">@State.Settings.Difficulty</span>
                        </div>
                    </div>
                </div>

                @if (!string.IsNullOrWhiteSpace(GameError))
                {
                    <div class="ranked-lobby-error-box">
                        <p class="ranked-lobby-message">@GameError</p>
                    </div>
                }

                @if (State.IsMatchmaking && State.MatchmakingEndsAtUtc != null)
                {
                    <div class="ranked-lobby-status-box">
                        <p class="ranked-lobby-message"><strong>Opponent found.</strong></p>
                        <p class="ranked-lobby-message">
                            Game starts in
                            <span class="ranked-lobby-highlight">
                                @Math.Max(0, (int)(State.MatchmakingEndsAtUtc.Value - DateTime.UtcNow).TotalSeconds)
                            </span>
                            seconds.
                        </p>
                    </div>
                }
                else if (!State.IsStarted)
                {
                    <div class="ranked-lobby-status-box">
                        <p class="ranked-lobby-message">
                            @(State.PlayerDetails.Count < 2
                                ? "Waiting for opponent..."
                                : "Match is starting...")
                        </p>
                    </div>
                }
            }
        </div>
    </div>
</div>

@if (ShowLeaveModal)
{
    <div class="leave-modal-overlay">
        <div class="leave-modal-card">
            <div class="leave-modal-icon">!</div>

            <h2 class="leave-modal-title">Leave ranked lobby?</h2>

            <p class="leave-modal-text">
                Do you really want to leave the ranked lobby?
                <br />
                You will be disconnected from the match queue.
            </p>

            <div class="leave-modal-actions">
                <button class="menu-btn leave-modal-btn-secondary" @onclick="CancelLeave">
                    Stay
                </button>

                <button class="menu-btn leave-modal-btn-danger" @onclick="ConfirmLeave">
                    Leave
                </button>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public string Code { get; set; } = "";

    private RankedLobbyState? State;
    private bool _navigated = false;
    private PeriodicTimer? _timer;
    private string? GameError;
    private bool _isLeaving = false;
    private bool ShowLeaveModal = false;
    private string? PendingTargetUrl;

    protected override async Task OnInitializedAsync()
    {
        await Auth.InitializeAsync();

        if (!Auth.IsLoggedIn)
        {
            Nav.NavigateTo("/profile", true);
            return;
        }

        var token = await Auth.GetTokenAsync();
        if (string.IsNullOrWhiteSpace(token))
        {
            Nav.NavigateTo("/profile", true);
            return;
        }

        await RankedMp.ConnectAsync(Nav.BaseUri.TrimEnd('/'), token);

        _timer = new PeriodicTimer(TimeSpan.FromSeconds(1));
        _ = Task.Run(async () =>
        {
            while (await _timer.WaitForNextTickAsync())
            {
                await InvokeAsync(StateHasChanged);
            }
        });

        RankedMp.OnLobbyUpdated += HandleLobbyUpdated;
        RankedMp.OnGameError += HandleGameError;
        RankedMp.OnNewQuestion += HandleNewQuestion;

        try
        {
            State = await RankedMp.GetRankedLobbyStateAsync(Code);
        }
        catch
        {
            Nav.NavigateTo("/multiplayerRanked", true);
        }
    }

    private void HandleLobbyUpdated(RankedLobbyState s)
    {
        if (s.Code != Code) return;

        State = s;

        if (State.IsStarted && !_navigated)
        {
            _navigated = true;
            Nav.NavigateTo($"/rankedMultiplayerGame/{Code}");
            return;
        }

        InvokeAsync(StateHasChanged);
    }
    
    private Task ConfirmLeaveNavigation(LocationChangingContext context)
    {
        if (_isLeaving)
            return Task.CompletedTask;

        var target = Nav.ToBaseRelativePath(context.TargetLocation).ToLowerInvariant();
        var gameTarget = $"rankedmultiplayergame/{Code}".ToLowerInvariant();

        if (target == gameTarget)
            return Task.CompletedTask;

        context.PreventNavigation();
        PendingTargetUrl = context.TargetLocation;
        ShowLeaveModal = true;

        InvokeAsync(StateHasChanged);
        return Task.CompletedTask;
    }

    private Task CancelLeave()
    {
        ShowLeaveModal = false;
        PendingTargetUrl = null;
        return InvokeAsync(StateHasChanged);
    }

    private async Task ConfirmLeave()
    {
        if (_isLeaving)
            return;

        _isLeaving = true;
        ShowLeaveModal = false;

        try
        {
            await RankedMp.LeaveRankedLobbyAsync(Code);
        }
        catch
        {
        }

        var target = PendingTargetUrl;
        PendingTargetUrl = null;

        if (string.IsNullOrWhiteSpace(target))
            await JS.InvokeVoidAsync("appNav.replace", "/multiplayerRanked");
        else
            await JS.InvokeVoidAsync("appNav.replace", target);
    }

    private void HandleGameError(string msg)
    {
        GameError = msg;
        InvokeAsync(StateHasChanged);
    }

    private async void HandleNewQuestion(TriviaQuestion q)
    {
        if (_navigated) return;
        _navigated = true;
        await Task.Delay(100);
        Nav.NavigateTo($"/rankedMultiplayerGame/{Code}");
    }

    public void Dispose()
    {
        _timer?.Dispose();
        RankedMp.OnLobbyUpdated -= HandleLobbyUpdated;
        RankedMp.OnGameError -= HandleGameError;
        RankedMp.OnNewQuestion -= HandleNewQuestion;
    }
    
    private string GetAvatarUrl(string? avatarKey)
    {
        var key = string.IsNullOrWhiteSpace(avatarKey) ? "default" : avatarKey;
        return $"/images/avatars/{key}.png";
    }
    
    private Task GoHome()
    {
        if (_isLeaving)
            return Task.CompletedTask;

        PendingTargetUrl = "/";
        ShowLeaveModal = true;
        return InvokeAsync(StateHasChanged);
    }
}