@page "/multiplayerCustomLobby/{Code}"
@using WebQuizGame.Classes.Models
@using WebQuizGame.Classes.Models.Multiplayer
@using WebQuizGame.Classes.Services
@inject MultiplayerClient Mp
@inject Authorization Auth
@inject NavigationManager Nav
@using Microsoft.AspNetCore.Components.Routing
@inject IJSRuntime JS
@implements IDisposable

<NavigationLock OnBeforeInternalNavigation="ConfirmLeaveNavigation" />

<div class="mp-custom-lobby-page">
    <button class="home-floating-btn home-with-text" @onclick="GoHome" title="Home">
        <img src="/images/avatars/macaroni.png" alt="Home" class="home-floating-img" />
        <span>Home</span>
    </button>
    <div class="mp-custom-lobby-screen">
        <h1 class="mp-custom-lobby-title">Custom Lobby</h1>
        <p class="mp-custom-lobby-subtitle">Manage players and game settings before the match starts</p>

        @if (State == null)
        {
            <div class="mp-custom-lobby-card">
                <p class="mp-custom-lobby-message">Loading lobby...</p>
            </div>
        }
        else
        {
            <div class="mp-custom-lobby-card">
                <div class="mp-custom-lobby-overview">
                    <div class="mp-custom-lobby-overview-box">
                        <span class="mp-custom-lobby-overview-label">Lobby Code</span>
                        <span class="mp-custom-lobby-overview-value">@State.Code</span>
                    </div>

                    <div class="mp-custom-lobby-overview-box">
                        <span class="mp-custom-lobby-overview-label">Host</span>
                        <span class="mp-custom-lobby-overview-value">@State.HostUsername</span>
                    </div>
                </div>

                <div class="mp-custom-lobby-section">
                    <h2 class="mp-custom-lobby-section-title">Players</h2>
                    <div class="mp-custom-lobby-players-box">
                        <p class="mp-custom-lobby-players-count">@State.PlayerDetails.Count / 4 players</p>

                        <div class="mp-custom-lobby-players-list">
                            @foreach (var player in State.PlayerDetails)
                            {
                                <div class="mp-custom-lobby-player-item mp-custom-lobby-player-row">
                                    <div class="mp-custom-lobby-player-avatar-wrap">
                                        <img class="mp-custom-lobby-player-avatar"
                                             src="@GetAvatarUrl(player.AvatarKey)"
                                             alt="avatar"/>
                                    </div>

                                    <span class="mp-custom-lobby-player-name">@player.Username</span>
                                </div>
                            }
                        </div>
                    </div>
                </div>

                @if (!string.IsNullOrWhiteSpace(GameError))
                {
                    <div class="mp-custom-lobby-error-box">
                        <p class="mp-custom-lobby-message">@GameError</p>
                    </div>
                }

                <div class="mp-custom-lobby-section">
                    <h2 class="mp-custom-lobby-section-title">Current Settings</h2>

                    <div class="mp-custom-lobby-settings-grid">
                        <div class="mp-custom-lobby-setting-box">
                            <span class="mp-custom-lobby-setting-label">Questions</span>
                            <span class="mp-custom-lobby-setting-value">@State.Settings.Amount</span>
                        </div>

                        <div class="mp-custom-lobby-setting-box">
                            <span class="mp-custom-lobby-setting-label">Time per question</span>
                            <span class="mp-custom-lobby-setting-value">@(State.Settings.TimePerQuestion == 0 ? "∞" : $"{State.Settings.TimePerQuestion}s")</span>
                        </div>

                        <div class="mp-custom-lobby-setting-box">
                            <span class="mp-custom-lobby-setting-label">Difficulty</span>
                            <span class="mp-custom-lobby-setting-value">@State.Settings.Difficulty</span>
                        </div>

                        <div class="mp-custom-lobby-setting-box mp-custom-lobby-setting-box-wide">
                            <span class="mp-custom-lobby-setting-label">Categories</span>
                            <span class="mp-custom-lobby-setting-value">
                                @(State.Settings.CategoryIds.Count == 0
                                    ? "Any"
                                    : string.Join(", ",
                                        Categories
                                            .Where(c => State.Settings.CategoryIds.Contains(c.Id))
                                            .Select(c => c.Name)))
                            </span>
                        </div>
                    </div>
                </div>

                @if (IsHost && !State.IsStarted)
                {
                    <div class="mp-custom-lobby-host-section">
                        <h2 class="mp-custom-lobby-section-title">Host Settings</h2>

                        <div class="mp-custom-lobby-field">
                            <label class="mp-custom-lobby-label">
                                Number of questions:
                                <span class="mp-custom-lobby-highlight">@(QuestionCount == MaxQuestionCount ? "∞" : QuestionCount.ToString())</span>
                            </label>
                            <input class="mp-custom-lobby-range"
                                   type="range"
                                   min="5"
                                   max="@MaxQuestionCount"
                                   step="1"
                                   @bind="QuestionCount"
                                   @bind:event="oninput"/>
                        </div>

                        <div class="mp-custom-lobby-field">
                            <label class="mp-custom-lobby-label">Time per question</label>
                            <select class="mp-custom-lobby-select" @bind="TimePerQuestion">
                                <option value="5">5 s</option>
                                <option value="10">10 s</option>
                                <option value="15">15 s</option>
                                <option value="30">30 s</option>
                                <option value="60">60 s</option>
                                <option value="120">120 s</option>
                                <option value="0">Infinite</option>
                            </select>
                        </div>

                        <div class="mp-custom-lobby-field">
                            <label class="mp-custom-lobby-label">
                                Select Categories
                                <span class="mp-custom-lobby-limit">(max 3)</span>
                            </label>

                            <div class="mp-custom-lobby-category-dropdown">
                                <button type="button"
                                        class="mp-custom-lobby-category-dropdown-toggle"
                                        @onclick="ToggleCategoryDropdown">
                                    <span>@CategoryDropdownText</span>
                                    <span class="mp-custom-lobby-category-dropdown-arrow @(IsCategoryDropdownOpen ? "open" : "")">⌄</span>
                                </button>

                                @if (IsCategoryDropdownOpen)
                                {
                                    <div class="mp-custom-lobby-category-dropdown-menu">
                                        @foreach (var cat in Categories)
                                        {
                                            <label class="mp-custom-lobby-category-dropdown-item">
                                                <input type="checkbox"
                                                       @onchange="() => ToggleCategory(cat.Id)"
                                                       checked="@SelectedCategoryIds.Contains(cat.Id)"
                                                       disabled="@(!SelectedCategoryIds.Contains(cat.Id) && SelectedCategoryIds.Count >= 3)"/>
                                                <span>@cat.Name</span>
                                            </label>
                                        }
                                    </div>
                                }
                            </div>

                            @if (SelectedCategoryIds.Any())
                            {
                                <div class="mp-custom-lobby-selected-category-tags">
                                    @foreach (var cat in Categories.Where(c => SelectedCategoryIds.Contains(c.Id)))
                                    {
                                        <div class="mp-custom-lobby-selected-category-tag">
                                            <span>@cat.Name</span>
                                            <button type="button" @onclick="() => ToggleCategory(cat.Id)">×</button>
                                        </div>
                                    }
                                </div>
                            }
                        </div>

                        <div class="mp-custom-lobby-field">
                            <p class="mp-custom-lobby-label">Difficulty</p>

                            <div class="mp-custom-lobby-difficulty">
                                @foreach (var diff in Difficulties)
                                {
                                    <label class="mp-custom-lobby-radio-item">
                                        <input type="radio"
                                               name="difficulty"
                                               value="@diff"
                                               @onchange="() => SelectedDifficulty = diff"
                                               checked="@SelectedDifficulty == diff"/>
                                        <span>@diff</span>
                                    </label>
                                }
                            </div>
                        </div>

                        <div class="mp-custom-lobby-actions">
                            <button class="menu-btn mp-custom-lobby-btn" @onclick="ApplySettings">
                                Apply Settings
                            </button>

                            <button class="menu-btn mp-custom-lobby-btn mp-custom-lobby-start-btn"
                                    @onclick="StartGame"
                                    disabled="@(State.Players.Count < 2)">
                                Start Game
                            </button>
                        </div>
                    </div>
                }

                @if (!IsHost && !State.IsStarted)
                {
                    <div class="mp-custom-lobby-status-box">
                        <p class="mp-custom-lobby-message">Waiting for the host to start the game...</p>
                    </div>
                }

                @if (State.IsStarted)
                {
                    <div class="mp-custom-lobby-status-box">
                        <p class="mp-custom-lobby-message"><strong>Game starting...</strong></p>
                    </div>
                }
            </div>
        }
    </div>
</div>

@if (ShowLeaveModal)
{
    <div class="leave-modal-overlay">
        <div class="leave-modal-card">
            <div class="leave-modal-icon">!</div>

            <h2 class="leave-modal-title">Leave custom lobby?</h2>

            <p class="leave-modal-text">
                Do you really want to leave the custom lobby?
                <br />
                You will be disconnected and returned to multiplayer.
            </p>

            <div class="leave-modal-actions">
                <button class="menu-btn leave-modal-btn-secondary" @onclick="CancelLeave">
                    Stay
                </button>

                <button class="menu-btn leave-modal-btn-danger" @onclick="ConfirmLeave">
                    Leave
                </button>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public string Code { get; set; } = "";

    private LobbyState? State;
    private bool _navigated = false;
    private string? GameError;
    private bool _isLeaving = false;
    private bool ShowLeaveModal = false;
    private string? PendingTargetUrl;

    private const int MaxQuestionCount = 50;
    private int QuestionCount = 10;
    private int TimePerQuestion = 10;
    private List<int> SelectedCategoryIds = new();
    private List<string> Difficulties = new() { "any", "easy", "medium", "hard" };
    private string SelectedDifficulty = "any";

    private bool IsHost => State != null && State.HostUsername == Mp.LocalUsername;

    private List<Category> Categories = new()
    {
        new Category { Id = 9,  Name = "General Knowledge" },
        new Category { Id = 10, Name = "Entertainment: Books" },
        new Category { Id = 11, Name = "Entertainment: Film" },
        new Category { Id = 12, Name = "Entertainment: Music" },
        new Category { Id = 13, Name = "Entertainment: Musicals & Theatres" },
        new Category { Id = 14, Name = "Entertainment: Television" },
        new Category { Id = 15, Name = "Entertainment: Video Games" },
        new Category { Id = 16, Name = "Entertainment: Board Games" },
        new Category { Id = 17, Name = "Science & Nature" },
        new Category { Id = 18, Name = "Science: Computers" },
        new Category { Id = 19, Name = "Science: Mathematics" },
        new Category { Id = 20, Name = "Mythology" },
        new Category { Id = 21, Name = "Sports" },
        new Category { Id = 22, Name = "Geography" },
        new Category { Id = 23, Name = "History" },
        new Category { Id = 24, Name = "Politics" },
        new Category { Id = 25, Name = "Art" },
        new Category { Id = 26, Name = "Celebrities" },
        new Category { Id = 27, Name = "Animals" },
        new Category { Id = 28, Name = "Vehicles" },
        new Category { Id = 29, Name = "Entertainment: Comics" },
        new Category { Id = 30, Name = "Science: Gadgets" },
        new Category { Id = 31, Name = "Entertainment: Japanese Anime & Manga" },
        new Category { Id = 32, Name = "Entertainment: Cartoon & Animations" }
    };

    protected override async Task OnInitializedAsync()
    {
        await Auth.InitializeAsync();
        await Mp.ConnectAsync(Nav.BaseUri.TrimEnd('/'));

        Mp.OnLobbyUpdated += HandleLobbyUpdated;
        Mp.OnGameError += HandleGameError;
        Mp.OnNewQuestion += HandleNewQuestion;

        try
        {
            State = await Mp.GetLobbyStateAsync(Code);

            if (State != null)
            {
                QuestionCount = State.Settings.Amount;
                TimePerQuestion = State.Settings.TimePerQuestion;
                SelectedDifficulty = State.Settings.Difficulty;
                SelectedCategoryIds = State.Settings.CategoryIds.ToList();
            }
        }
        catch
        {
            Nav.NavigateTo("/multiplayer", true);
        }
    }
    
    private Task ConfirmLeaveNavigation(LocationChangingContext context)
    {
        if (_isLeaving)
            return Task.CompletedTask;

        var target = Nav.ToBaseRelativePath(context.TargetLocation).ToLowerInvariant();
        var gameTarget = $"multiplayergame/{Code}".ToLowerInvariant();

        if (target == gameTarget)
            return Task.CompletedTask;

        context.PreventNavigation();
        PendingTargetUrl = context.TargetLocation;
        ShowLeaveModal = true;

        InvokeAsync(StateHasChanged);
        return Task.CompletedTask;
    }

    private Task CancelLeave()
    {
        ShowLeaveModal = false;
        PendingTargetUrl = null;
        return InvokeAsync(StateHasChanged);
    }

    private async Task ConfirmLeave()
    {
        if (_isLeaving)
            return;

        _isLeaving = true;
        ShowLeaveModal = false;

        try
        {
            await Mp.LeaveLobbyAsync(Code);
        }
        catch
        {
        }

        var target = PendingTargetUrl;
        PendingTargetUrl = null;

        if (string.IsNullOrWhiteSpace(target))
            await JS.InvokeVoidAsync("appNav.replace", "/multiplayer");
        else
            await JS.InvokeVoidAsync("appNav.replace", target);
    }

    private void HandleLobbyUpdated(LobbyState s)
    {
        if (s.Code != Code) return;

        State = s;
        QuestionCount = s.Settings.Amount;
        TimePerQuestion = s.Settings.TimePerQuestion;
        SelectedDifficulty = s.Settings.Difficulty;
        SelectedCategoryIds = s.Settings.CategoryIds.ToList();

        if (State.IsStarted && !_navigated)
        {
            _navigated = true;
            Nav.NavigateTo($"/multiplayerGame/{Code}");
            return;
        }

        InvokeAsync(StateHasChanged);
    }

    private void HandleGameError(string msg)
    {
        GameError = msg;
        InvokeAsync(StateHasChanged);
    }

    private async void HandleNewQuestion(TriviaQuestion q)
    {
        if (_navigated) return;
        _navigated = true;
        await Task.Delay(100);
        Nav.NavigateTo($"/multiplayerGame/{Code}");
    }

    private void ToggleCategory(int id)
    {
        if (SelectedCategoryIds.Contains(id))
            SelectedCategoryIds.Remove(id);
        else if (SelectedCategoryIds.Count < 3)
            SelectedCategoryIds.Add(id);
    }

    private async Task ApplySettings()
    {
        var settings = new LobbySettings(
            QuestionCount,
            TimePerQuestion,
            SelectedDifficulty,
            SelectedCategoryIds.ToList());

        await Mp.UpdateSettingsAsync(Code, settings);
    }

    private async Task StartGame()
    {
        await Mp.StartGameAsync(Code);
    }

    public void Dispose()
    {
        Mp.OnLobbyUpdated -= HandleLobbyUpdated;
        Mp.OnGameError -= HandleGameError;
        Mp.OnNewQuestion -= HandleNewQuestion;
    }
    
    private bool IsCategoryDropdownOpen = false;

    private string CategoryDropdownText =>
        SelectedCategoryIds.Count == 0
            ? "Choose categories"
            : string.Join(", ",
                Categories
                    .Where(c => SelectedCategoryIds.Contains(c.Id))
                    .Select(c => c.Name));

    private void ToggleCategoryDropdown()
    {
        IsCategoryDropdownOpen = !IsCategoryDropdownOpen;
    }
    
    private string GetAvatarUrl(string? avatarKey)
    {
        var key = string.IsNullOrWhiteSpace(avatarKey) ? "default" : avatarKey;
        return $"/images/avatars/{key}.png";
    }
    
    private Task GoHome()
    {
        if (_isLeaving)
            return Task.CompletedTask;

        PendingTargetUrl = "/";
        ShowLeaveModal = true;
        return InvokeAsync(StateHasChanged);
    }
}