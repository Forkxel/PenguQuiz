@page "/multiplayerGame/{Code}"
@using WebQuizGame.Classes.Models
@using WebQuizGame.Classes.Services
@inject MultiplayerClient Mp

<div class="multiplayer-game-page">
    <div class="multiplayer-game-screen">
        <h1 class="multiplayer-game-title">Multiplayer Game</h1>
        <p class="multiplayer-game-subtitle">Lobby code: @Code</p>

        @if (Finished)
        {
            <div class="multiplayer-game-card multiplayer-game-finish-card">
                <h2 class="multiplayer-game-finish-title">Game Over</h2>

                <div class="multiplayer-game-scoreboard">
                    @foreach (var s in Scores.OrderByDescending(x => x.Value))
                    {
                        <div class="multiplayer-game-score-row">
                            <span class="multiplayer-game-player">@s.Key</span>
                            <span class="multiplayer-game-points">@s.Value</span>
                        </div>
                    }
                </div>
            </div>
        }
        else if (Current == null)
        {
            <div class="multiplayer-game-card">
                <p class="multiplayer-game-message">Waiting for question...</p>
            </div>
        }
        else
        {
            <div class="multiplayer-game-card">
                <div class="multiplayer-game-question-box">
                    <p class="multiplayer-game-question-label">Current Question</p>
                    <h2 class="multiplayer-game-question">@Current.Question</h2>
                </div>

                <div class="multiplayer-game-answers">
                    @foreach (var a in Answers)
                    {
                        <button class="multiplayer-game-answer-btn menu-btn"
                                @onclick="() => Answer(a)"
                                disabled="@Locked">
                            @a
                        </button>
                    }
                </div>

                @if (!string.IsNullOrWhiteSpace(Message))
                {
                    <div class="multiplayer-game-info-box">
                        <p class="multiplayer-game-message">@Message</p>
                    </div>
                }
            </div>
        }
    </div>
</div>

@code {
    [Parameter] public string Code { get; set; } = "";

    private TriviaQuestion? Current;
    private List<string> Answers = new();
    private bool Locked = false;
    private string Message = "";
    private bool Finished = false;

    private Dictionary<string,int> Scores = new();

    protected override async Task OnInitializedAsync()
    {
        await Mp.ConnectAsync("http://localhost:5237");

        Mp.OnNewQuestion += q =>
        {
            Current = q;
            Answers = q.IncorrectAnswers
                .Append(q.CorrectAnswer)
                .OrderBy(_ => Guid.NewGuid())
                .ToList();
            Locked = false;
            Message = "";
            InvokeAsync(StateHasChanged);
        };

        Mp.OnQuestionWon += winner =>
        {
            Locked = true;
            Message = $"{winner} answered correctly!";
            InvokeAsync(StateHasChanged);
        };
        
        Mp.OnQuestionResolved += (who, chosen, correct) =>
        {
            Locked = true;
            Message = who == "TIMEOUT"
                ? "Time's up! Nobody answered."
                : $"{who} clicked \"{chosen}\" -> {(correct ? "CORRECT" : "WRONG")}";
            InvokeAsync(StateHasChanged);
        };

        Mp.OnGameFinished += scores =>
        {
            Finished = true;
            Scores = scores;
            InvokeAsync(StateHasChanged);
        };
        
        var q = await Mp.GetCurrentQuestionAsync(Code);
        if (q != null)
        {
            Current = q;
            Answers = q.IncorrectAnswers
                .Append(q.CorrectAnswer)
                .OrderBy(_ => Guid.NewGuid())
                .ToList();
            Locked = false;
            Message = "";
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task Answer(string ans)
    {
        if (Locked) return;
        Locked = true;
        await Mp.AnswerQuestionAsync(Code, ans);
    }
}