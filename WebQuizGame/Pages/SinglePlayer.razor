@page "/singleplayer"
@using WebQuizGame.Classes.Models
@inject NavigationManager Navigation
@inject HttpClient Http

<div class="single-game-page">
    <div class="single-game-screen">
        <h1 class="single-game-title">Quiz Game</h1>
        <p class="single-game-subtitle">Answer the questions as fast as you can</p>

        @if (Questions == null || Questions.Count == 0)
        {
            <div class="single-game-card">
                <p class="single-game-message">Loading questions...</p>
            </div>
        }
        else if (CurrentQuestionIndex < Questions.Count)
        {
            <div class="single-game-topbar">
                <div class="single-game-stat">
                    <span class="single-game-stat-label">Score</span>
                    <span class="single-game-stat-value">@Score</span>
                </div>

                @if (time > 0)
                {
                    <div class="single-game-stat">
                        <span class="single-game-stat-label">Time Left</span>
                        <span class="single-game-stat-value">@TimeLeft s</span>
                    </div>
                }
            </div>

            <div class="single-game-card">
                <div class="single-game-question-box">
                    <p class="single-game-question-number">Question @(CurrentQuestionIndex + 1)</p>
                    <p class="single-game-question-text">
                        @Questions[CurrentQuestionIndex]?.Text
                    </p>
                </div>

                <div class="single-game-answers">
                    @if (Questions[CurrentQuestionIndex]?.Type == "boolean")
                    {
                        <button disabled="@Answered"
                                class="answer-btn single-game-answer-btn @GetAnswerClass("True")"
                                @onclick="CheckTrue">
                            True
                        </button>

                        <button disabled="@Answered"
                                class="answer-btn single-game-answer-btn @GetAnswerClass("False")"
                                @onclick="CheckFalse">
                            False
                        </button>
                    }
                    else
                    {
                        @foreach (var ans in Questions[CurrentQuestionIndex]?.Answers ?? new())
                        {
                            <button disabled="@Answered"
                                    class="answer-btn single-game-answer-btn @GetAnswerClass(ans)"
                                    @onclick="() => CheckAnswer(ans)">
                                @ans
                            </button>
                        }
                    }
                </div>
            </div>
        }
        else
        {
            <div class="single-game-card single-game-finish-card">
                <h2 class="single-game-finish-title">Quiz Finished!</h2>

                <div class="single-game-summary">
                    <div class="single-game-summary-box">
                        <span class="single-game-summary-label">Total Score</span>
                        <span class="single-game-summary-value">@Score</span>
                    </div>

                    <div class="single-game-summary-box">
                        <span class="single-game-summary-label">Correct Answers</span>
                        <span class="single-game-summary-value">@AnswerRecords.Count(a => a.IsCorrect)</span>
                    </div>

                    <div class="single-game-summary-box">
                        <span class="single-game-summary-label">Total Questions</span>
                        <span class="single-game-summary-value">@Questions.Count</span>
                    </div>

                    @if (AnswerRecords.Count > 0)
                    {
                        var timed = AnswerRecords.Where(a => a.TimeTaken > 0).ToList();

                        if (timed.Any())
                        {
                            <div class="single-game-summary-box">
                                <span class="single-game-summary-label">Average Time</span>
                                <span class="single-game-summary-value">@Math.Round(timed.Average(a => a.TimeTaken), 2) s</span>
                            </div>

                            <div class="single-game-summary-box">
                                <span class="single-game-summary-label">Total Time</span>
                                <span class="single-game-summary-value">@Math.Round(timed.Sum(a => a.TimeTaken), 2) s</span>
                            </div>
                        }
                    }
                </div>

                <div class="single-game-actions">
                    <button class="menu-btn single-game-menu-btn" @onclick="RestartGame">Restart Game</button>
                    <button class="menu-btn single-game-menu-btn single-game-secondary-btn" @onclick="GoToMenu">Singleplayer Menu</button>
                </div>
            </div>
        }
    </div>
</div>

@code {

    [Parameter, SupplyParameterFromQuery] public string? categories { get; set; }
    [Parameter, SupplyParameterFromQuery] public string? difficulty { get; set; }
    [Parameter, SupplyParameterFromQuery] public int amount { get; set; }
    [Parameter, SupplyParameterFromQuery] public int time { get; set; }

    private List<Question> Questions = new();
    private int CurrentQuestionIndex = 0;
    private int Score = 0;
    private bool Answered = false;
    private string? SelectedAnswer;
    private bool ForceFreshOnNextLoad = false;

    private int TimeLeft;
    private CancellationTokenSource? TimerCts;

    private List<AnswerRecord> AnswerRecords = new();

    private DateTime? QuestionStartTime;
    private bool IsLoadingQuestions = false;

    protected override async Task OnInitializedAsync()
    {
        await LoadQuestionsAsync();

        if (Questions.Count > 0)
            StartQuestionTimer();
    }

    private async Task LoadQuestionsAsync()
    {
        if (IsLoadingQuestions) return;
        IsLoadingQuestions = true;

        Questions = new();
        
        var query = new List<string>
        {
            $"amount={amount}"
        };

        if (!string.IsNullOrWhiteSpace(difficulty))
            query.Add($"difficulty={difficulty}");

        if (!string.IsNullOrWhiteSpace(categories))
            query.Add($"categories={categories}");

        if (ForceFreshOnNextLoad)
        {
            query.Add("fresh=true");
            ForceFreshOnNextLoad = false;
        }

        var url = "api/trivia?" + string.Join("&", query);

        var response = await Http.GetAsync(url);
        if (!response.IsSuccessStatusCode)
        {
            IsLoadingQuestions = false;
            return;
        }

        var data = await response.Content.ReadFromJsonAsync<TriviaResponse>();

        if (data?.Results != null && data.Results.Count > 0)
            Questions.AddRange(ParseTrivia(data));

        Questions = Questions.OrderBy(_ => Guid.NewGuid()).ToList();

        IsLoadingQuestions = false;
        StateHasChanged();
    }

    private async Task CheckAnswer(string selected)
    {
        if (Answered || CurrentQuestionIndex >= Questions.Count)
        {
            return;
        }

        Answered = true;
        SelectedAnswer = selected;

        TimerCts?.Cancel();

        double timeTaken = 0;

        if (QuestionStartTime.HasValue && time > 0)
        {
            timeTaken = (DateTime.UtcNow - QuestionStartTime.Value).TotalSeconds;
        }

        var q = Questions[CurrentQuestionIndex];

        AnswerRecords.Add(new AnswerRecord
        {
            Question = q,
            IsCorrect = selected == q.CorrectAnswer,
            TimeTaken = timeTaken
        });

        if (selected == q.CorrectAnswer)
        {
            Score += 10;
        }

        StateHasChanged();

        await Task.Delay(800);

        Answered = false;
        SelectedAnswer = null;
        CurrentQuestionIndex++;

        if (CurrentQuestionIndex < Questions.Count)
        {
            StartQuestionTimer();
        }

        StateHasChanged();
    }

    private void CheckTrue() => _ = CheckAnswer("True");
    private void CheckFalse() => _ = CheckAnswer("False");

    private void StartQuestionTimer()
    {
        QuestionStartTime = DateTime.UtcNow;

        if (time <= 0) return;

        TimerCts?.Cancel();
        TimerCts = new CancellationTokenSource();

        TimeLeft = time;

        _ = RunTimer(TimerCts.Token);
    }

    private async Task RunTimer(CancellationToken token)
    {
        try
        {
            while (TimeLeft > 0 && !token.IsCancellationRequested)
            {
                await Task.Delay(1000, token);
                TimeLeft--;
                StateHasChanged();
            }

            if (TimeLeft == 0 && !Answered)
                await CheckAnswer("TIMEOUT");
        }
        catch { }
    }

    private string GetAnswerClass(string answer)
    {
        if (!Answered || CurrentQuestionIndex >= Questions.Count)
            return "";

        var correct = Questions[CurrentQuestionIndex].CorrectAnswer;

        if (answer == correct) return "correct";
        if (answer == SelectedAnswer) return "wrong";

        return "disabled";
    }

    private async Task RestartGame()
    {
        TimerCts?.Cancel();
        TimerCts = null;

        Questions = new();
        AnswerRecords = new();
        CurrentQuestionIndex = 0;
        Score = 0;
        SelectedAnswer = null;
        Answered = false;

        ForceFreshOnNextLoad = true;
        
        await LoadQuestionsAsync();

        if (Questions.Count > 0)
            StartQuestionTimer();
    }

    private void GoToMenu()
    {
        Navigation.NavigateTo("/singleplayerMenu");
    }

    private List<Question> ParseTrivia(TriviaResponse response)
    {
        return response.Results.Select(r => new Question
        {
            Text = System.Net.WebUtility.HtmlDecode(r.Question),
            CorrectAnswer = System.Net.WebUtility.HtmlDecode(r.CorrectAnswer),
            Type = r.Type,
            Answers = r.Type == "multiple"
                ? r.IncorrectAnswers
                    .Select(a => System.Net.WebUtility.HtmlDecode(a))
                    .Append(System.Net.WebUtility.HtmlDecode(r.CorrectAnswer))
                    .OrderBy(_ => Guid.NewGuid())
                    .ToList()
                : new List<string> { "True", "False" }
        }).ToList();
    }
}