@page "/singleplayer"
@using WebQuizGame.Classes
@inject NavigationManager Navigation
@inject HttpClient Http

<h2>Quiz Game</h2>

@if (Questions == null || Questions.Count == 0)
{
    <p>Loading questions...</p>
}
else if (CurrentQuestionIndex < Questions.Count)
{
    <p>Score: @Score</p>

    @if (time > 0)
    {
        <p>Time left: @TimeLeft s</p>
    }

    <div>
        <p><strong>Question @(@CurrentQuestionIndex + 1):</strong> @Questions[CurrentQuestionIndex]?.Text</p>

        @if (Questions[CurrentQuestionIndex]?.Type == "boolean")
        {
            <button class="answer-btn @GetAnswerClass("True")"
                    disabled="@Answered"
                    @onclick="CheckTrue">True</button>
            <button class="answer-btn @GetAnswerClass("False")"
                    disabled="@Answered"
                    @onclick="CheckFalse">False</button>
        }
        else
        {
            @foreach(var ans in Questions[CurrentQuestionIndex]?.Answers ?? new List<string>())
            {
                <button class="answer-btn @GetAnswerClass(ans)"
                        disabled="@Answered"
                        @onclick="() => CheckAnswer(ans)">
                    @ans
                </button>
            }
        }
    </div>
}
else
{
    <div class="final-score">
        <h2>Quiz Finished!</h2>
        <p>Total Score: @Score</p>
        <p>Correct Answers: @AnswerRecords.Count(a => a.IsCorrect)</p>
        <p>Total Questions: @Questions.Count</p>

        @if (AnswerRecords.Count > 0)
        {
            var timedAnswers = AnswerRecords.Where(a => a.TimeTaken > 0).ToList();
            if (timedAnswers.Any())
            {
                <p>Average Time per Answer: @Math.Round(timedAnswers.Average(a => a.TimeTaken), 2) s</p>
                <p>Total Time: @Math.Round((decimal)timedAnswers.Sum(a => a.TimeTaken), 2) s</p>
            }
        }

        <button class="menu-btn" @onclick="RestartGame">Restart Game</button>
        <button class="menu-btn" @onclick="GoToMenu">Menu</button>
    </div>
}

@code {
    [Parameter, SupplyParameterFromQuery] public string? categories { get; set; }
    [Parameter, SupplyParameterFromQuery] public string? difficulty { get; set; }
    [Parameter, SupplyParameterFromQuery] public int amount { get; set; }
    [Parameter, SupplyParameterFromQuery] public int time { get; set; }

    private List<Question>? Questions;
    private int CurrentQuestionIndex = 0;
    private int Score = 0;
    private string? SelectedAnswer;
    private bool Answered = false;
    private int TimeLeft;
    private CancellationTokenSource? TimerCts;
    private List<AnswerRecord> AnswerRecords = new();
    private DateTime? QuestionStartTime;

    protected override async Task OnInitializedAsync()
    {
        Questions = new List<Question>();
        AnswerRecords = new List<AnswerRecord>();
        CurrentQuestionIndex = 0;
        Score = 0;

        await LoadQuestionsAsync();
        if (Questions.Count > 0)
        {
            StartQuestionTimer();
        }
    }

    private async Task LoadQuestionsAsync()
    {
        if (string.IsNullOrWhiteSpace(categories))
        {
            await LoadAnyCategory();
            return;
        }

        var categoryIds = categories.Split(',').Select(int.Parse).ToList();
        int amountPerCategory = Math.Max(1, amount / categoryIds.Count);

        for (int i = 0; i < categoryIds.Count; i++)
        {
            await LoadCategory(categoryIds[i], amountPerCategory);

            if (i < categoryIds.Count - 1)
                await Task.Delay(5000);
        }
    }

    private async Task LoadAnyCategory()
    {
        var url = $"https://opentdb.com/api.php?amount={amount}";

        if (!string.IsNullOrWhiteSpace(difficulty) && difficulty != "any")
            url += $"&difficulty={difficulty}";

        var response = await Http.GetFromJsonAsync<TriviaResponse>(url);

        if (response?.Results != null)
        {
            Questions!.AddRange(ParseTrivia(response));
            ShuffleRemainingQuestions();
            StateHasChanged();
        }
    }

    private async Task LoadCategory(int categoryId, int amount)
    {
        var url = $"https://opentdb.com/api.php?amount={amount}&category={categoryId}";

        if (!string.IsNullOrWhiteSpace(difficulty) && difficulty != "any")
            url += $"&difficulty={difficulty}";

        var response = await Http.GetFromJsonAsync<TriviaResponse>(url);

        if (response?.Results != null)
        {
            Questions!.AddRange(ParseTrivia(response));
            ShuffleRemainingQuestions();
            StateHasChanged();
        }
    }

    private void ShuffleRemainingQuestions()
    {
        var answered = Questions!.Take(CurrentQuestionIndex).ToList();
        var remaining = Questions.Skip(CurrentQuestionIndex).OrderBy(_ => Guid.NewGuid()).ToList();

        Questions = answered.Concat(remaining).ToList();
    }

    private async Task CheckAnswer(string selected)
    {
        if (Answered || Questions == null) return;

        Answered = true;
        SelectedAnswer = selected;
        
        TimerCts?.Cancel();
        
        int timeTaken = 0;
        if (QuestionStartTime.HasValue && time > 0)
        {
            timeTaken = (int)(DateTime.UtcNow - QuestionStartTime.Value).TotalSeconds;
        }
        
        var current = Questions[CurrentQuestionIndex];
        AnswerRecords.Add(new AnswerRecord
        {
            Question = current,
            IsCorrect = selected == current.CorrectAnswer,
            TimeTaken = timeTaken
        });

        if (selected == current.CorrectAnswer)
        {
            Score += 10;
        }

        StateHasChanged();

        await Task.Delay(800);

        SelectedAnswer = null;
        Answered = false;
        CurrentQuestionIndex++;

        if (CurrentQuestionIndex < Questions.Count)
        {
            StartQuestionTimer();
        }

        StateHasChanged();
    }

    private List<Question> ParseTrivia(TriviaResponse response)
    {
        return response.Results.Select(r => new Question
        {
            Text = System.Net.WebUtility.HtmlDecode(r.Question),
            CorrectAnswer = System.Net.WebUtility.HtmlDecode(r.CorrectAnswer),
            Type = r.Type,
            Answers = r.Type == "multiple"
                ? r.IncorrectAnswers
                    .Select(a => System.Net.WebUtility.HtmlDecode(a))
                    .Append(System.Net.WebUtility.HtmlDecode(r.CorrectAnswer))
                    .OrderBy(_ => Guid.NewGuid())
                    .ToList()
                : new List<string> { "True", "False" }
        }).ToList();
    }

    private string GetAnswerClass(string answer)
    {
        if (!Answered || Questions == null || CurrentQuestionIndex >= Questions.Count)
        {
            return "";
        }
          
        var correct = Questions[CurrentQuestionIndex].CorrectAnswer;
        if (answer == correct)
        {
            return "correct";
        }

        if (answer == SelectedAnswer)
        {
            return "wrong";
        }
        return "disabled";
    }


    private void CheckTrue()
    {
        CheckAnswer("True"); 
    }

    private void CheckFalse()
    {
        CheckAnswer("False");
    }
    
    private void StartTimer()
    {
        if (time == 0)
        {
            return;
        }
           
        TimerCts?.Cancel();
        TimerCts = new CancellationTokenSource();

        TimeLeft = time;
        QuestionStartTime = DateTime.Now;
        _ = RunTimer(TimerCts.Token);
    }
    
    private async Task RunTimer(CancellationToken token)
    {
        while (TimeLeft > 0 && !token.IsCancellationRequested)
        {
            await Task.Delay(1000, token);
            TimeLeft--;

            StateHasChanged();
        }

        if (TimeLeft == 0 && !Answered)
        {
            await CheckAnswer("TIMEOUT");
        }
    }
    
    private async Task RestartGame()
    {
        TimerCts?.Cancel();
        TimerCts = null;

        Questions = new List<Question>();
        AnswerRecords = new List<AnswerRecord>();
        CurrentQuestionIndex = 0;
        Score = 0;
        SelectedAnswer = null;
        Answered = false;

        StateHasChanged();

        await LoadQuestionsAsync();

        if (Questions.Count > 0)
            StartQuestionTimer();
    }

    private void StartQuestionTimer()
    {
        QuestionStartTime = DateTime.UtcNow;
        if (time > 0)
        {
            StartTimer();
        }
    }

    private void GoToMenu()
    {
        Navigation.NavigateTo("/singleplayerMenu");
    }
}