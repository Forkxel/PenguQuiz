@page "/"

<div class="menu-screen">
    <h1 class="menu-title">Quiz Game</h1>
    <p class="menu-subtitle">Choose your mode and start playing</p>

    <div class="menu-container">
        <button class="menu-btn" @onclick="GoToSingleplayer">Singleplayer</button>
        <button class="menu-btn" @onclick="GoToMultiplayer">Multiplayer</button>
        <button class="menu-btn" @onclick="GoToProfile">Profile</button>
        <!-- <button class="menu-btn exit" @onclick="ExitGame">Exit</button> -->
    </div>
</div>

@code {
    [Inject] NavigationManager Navigation { get; set; } = default!;

    private void GoToSingleplayer()
        => Navigation.NavigateTo("/singleplayerMenu");

    private void GoToMultiplayer()
        => Navigation.NavigateTo("/multiplayer");

    private void GoToProfile()
        => Navigation.NavigateTo("/profile");
}