@page "/rankedMultiplayerGame/{Code}"
@using WebQuizGame.Classes.Models
@using WebQuizGame.Classes.Models.Multiplayer.MultiplayerRanked
@using WebQuizGame.Classes.Services
@inject RankedMultiplayerClient RankedMp
@inject Authorization Auth
@inject NavigationManager Nav
@implements IDisposable

<div class="ranked-mp-game-page">
    <div class="ranked-mp-game-screen">
        <h1 class="ranked-mp-game-title">Ranked Multiplayer</h1>
        <p class="ranked-mp-game-subtitle">Answer quickly and climb the ladder</p>

        @if (Finished && FinalResult != null)
        {
            <div class="ranked-mp-game-card ranked-mp-game-finish-card">
                <h2 class="ranked-mp-game-finish-title">Match Finished</h2>

                <div class="ranked-mp-game-results">
                    @foreach (var r in FinalResult.Results.OrderBy(x => x.Place).ThenBy(x => x.Username))
                    {
                        <div class="ranked-mp-game-result-item">
                            <div class="ranked-mp-game-result-header">
                                <span class="ranked-mp-game-result-name">
                                    #@r.Place - @r.Username @(r.IsWinner ? "(Winner)" : "")
                                </span>
                            </div>

                            <div class="ranked-mp-game-result-stats">
                                <div class="ranked-mp-game-result-box">
                                    <span class="ranked-mp-game-result-label">Score</span>
                                    <span class="ranked-mp-game-result-value">@r.Score</span>
                                </div>

                                <div class="ranked-mp-game-result-box">
                                    <span class="ranked-mp-game-result-label">Old Rating</span>
                                    <span class="ranked-mp-game-result-value">@r.OldRating</span>
                                </div>

                                <div class="ranked-mp-game-result-box">
                                    <span class="ranked-mp-game-result-label">New Rating</span>
                                    <span class="ranked-mp-game-result-value">@r.NewRating</span>
                                </div>

                                <div class="ranked-mp-game-result-box">
                                    <span class="ranked-mp-game-result-label">Change</span>
                                    <span class="ranked-mp-game-result-value">
                                        @(r.Delta >= 0 ? "+" : "")@r.Delta
                                    </span>
                                </div>
                            </div>
                        </div>
                    }
                </div>

                <div class="ranked-mp-game-actions">
                    <button class="menu-btn ranked-mp-game-menu-btn" @onclick="BackToMenu">Back</button>
                </div>
            </div>
        }
        else if (Current == null)
        {
            <div class="ranked-mp-game-card">
                <p class="ranked-mp-game-message">Waiting for question...</p>
            </div>
        }
        else
        {
            <div class="ranked-mp-game-card">
                @if (!string.IsNullOrWhiteSpace(Message))
                {
                    <div class="ranked-mp-game-info-box">
                        <p class="ranked-mp-game-message">@Message</p>
                    </div>
                }

                <div class="ranked-mp-game-question-box">
                    <p class="ranked-mp-game-question-label">Current Question</p>
                    <h2 class="ranked-mp-game-question">@Current.Question</h2>
                </div>

                <div class="ranked-mp-game-answers">
                    @foreach (var a in Answers)
                    {
                        <button class="menu-btn ranked-mp-game-answer-btn"
                                @onclick="() => Answer(a)"
                                disabled="@Locked">
                            @a
                        </button>
                    }
                </div>
            </div>
        }
    </div>
</div>

@code {
    [Parameter] public string Code { get; set; } = "";

    private TriviaQuestion? Current;
    private List<string> Answers = new();
    private bool Locked = false;
    private string Message = "";
    private bool Finished = false;
    private RankedGameFinishedDto? FinalResult;

    protected override async Task OnInitializedAsync()
    {
        await Auth.InitializeAsync();

        if (!Auth.IsLoggedIn)
        {
            Nav.NavigateTo("/profile", true);
            return;
        }

        var token = await Auth.GetTokenAsync();
        if (string.IsNullOrWhiteSpace(token))
        {
            Nav.NavigateTo("/profile", true);
            return;
        }

        await RankedMp.ConnectAsync("http://localhost:5237", token);

        RankedMp.OnNewQuestion += HandleNewQuestion;
        RankedMp.OnQuestionResolved += HandleQuestionResolved;
        RankedMp.OnGameFinished += HandleGameFinished;
        RankedMp.OnGameError += HandleGameError;

        var q = await RankedMp.GetCurrentRankedQuestionAsync(Code);
        if (q != null)
            SetQuestion(q);
    }

    private void HandleNewQuestion(TriviaQuestion q)
    {
        SetQuestion(q);
        InvokeAsync(StateHasChanged);
    }

    private void SetQuestion(TriviaQuestion q)
    {
        Current = q;
        Answers = q.IncorrectAnswers
            .Append(q.CorrectAnswer)
            .OrderBy(_ => Guid.NewGuid())
            .ToList();

        Locked = false;
        Message = "";
    }

    private void HandleQuestionResolved(string who, string chosen, bool correct)
    {
        Locked = true;
        Message = who == "TIMEOUT"
            ? "Time's up! Nobody answered."
            : $"{who} clicked \"{chosen}\" -> {(correct ? "CORRECT" : "WRONG")}";

        InvokeAsync(StateHasChanged);
    }

    private void HandleGameFinished(RankedGameFinishedDto dto)
    {
        if (dto.LobbyCode != Code) return;

        Finished = true;
        FinalResult = dto;
        Locked = true;

        InvokeAsync(StateHasChanged);
    }

    private void HandleGameError(string msg)
    {
        Message = msg;
        InvokeAsync(StateHasChanged);
    }

    private async Task Answer(string ans)
    {
        if (Locked) return;

        Locked = true;
        await RankedMp.AnswerRankedQuestionAsync(Code, ans);
    }

    private void BackToMenu()
    {
        Nav.NavigateTo("/multiplayerRanked");
    }

    public void Dispose()
    {
        RankedMp.OnNewQuestion -= HandleNewQuestion;
        RankedMp.OnQuestionResolved -= HandleQuestionResolved;
        RankedMp.OnGameFinished -= HandleGameFinished;
        RankedMp.OnGameError -= HandleGameError;
    }
}