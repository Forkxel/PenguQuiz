@page "/profile"
@using WebQuizGame.Classes.Models
@inject NavigationManager Navigation
@inject HttpClient Http
@inject Authorization Auth
@inject Blazored.LocalStorage.ILocalStorageService LocalStorage

<div class="profile-page">
    <div class="profile-screen">
        <h1 class="profile-title">Account</h1>
        <p class="profile-subtitle">Login or create a new account</p>

        <div class="profile-container">
            <div class="profile-form">
                <input class="profile-input" placeholder="Username" @bind="Username" />
                <input class="profile-input" placeholder="Password" type="password" @bind="Password" />

                <div class="profile-actions">
                    <button class="profile-btn" @onclick="Login">Login</button>
                    <button class="profile-btn profile-btn-secondary" @onclick="Register">Register</button>
                </div>

                @if (!string.IsNullOrWhiteSpace(Message))
                {
                    <p class="profile-message">@Message</p>
                }
            </div>
        </div>
    </div>
</div>

@code {
    private string Username = "";
    private string Password = "";
    private string Message = "";

    private async Task Login()
    {
        var response = await Http.PostAsJsonAsync(
            "api/auth/login",
            new UserDto
            {
                Username = Username,
                Password = Password
            });

        if (!response.IsSuccessStatusCode)
        {
            var errorText = await response.Content.ReadAsStringAsync();
            Message = $"Login failed: {errorText}";
            return;
        }

        var result = await response.Content.ReadFromJsonAsync<LoginResponse>();

        if (result == null)
        {
            Message = "Login failed!";
            return;
        }

        await Auth.Login(result);

        Message = "";
        Navigation.NavigateTo("/profileMenu");
    }

    private async Task Register()
    {
        var response = await Http.PostAsJsonAsync(
            "api/auth/register",
            new UserDto
            {
                Username = Username,
                Password = Password
            });

        Message = response.IsSuccessStatusCode
            ? "Registration successful! Now log in."
            : "Username already exists!";
    }

    protected override async Task OnInitializedAsync()
    {
        await Auth.InitializeAsync();

        if (Auth.IsLoggedIn)
        {
            Navigation.NavigateTo("/profileMenu");
        }
    }
}