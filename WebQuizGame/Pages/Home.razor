@page "/"
@using System.Timers
@using WebQuizGame.Classes
<h3>Quiz Game – Timed Questions</h3>

@if (CurrentQuestionIndex < Questions.Count)
{
    <div>
        <p><strong>Question @(@CurrentQuestionIndex + 1):</strong> @CurrentQuestion.Text</p>
        <p>Time left: @TimeLeft s</p>

        @foreach (var answer in ShuffledAnswers)
        {
            <button class="answer-btn" @onclick="() => CheckAnswer(answer)" disabled="@IsAnswered">
                @answer
            </button>
        }
    </div>

    @if (ResultMessage != null)
    {
        <p>@ResultMessage</p>
    }
}
else
{
    <p>Quiz finished! Your final score: @Score</p>
}

@code {
    private List<Question> Questions = new List<Question>
    {
        new Question
        {
            Text = "What is the capital of France?",
            CorrectAnswer = "Paris",
            Answers = new List<string> { "Paris", "Lyon", "Marseille", "Bordeaux" }
        },
        new Question
        {
            Text = "Which planet is known as the Red Planet?",
            CorrectAnswer = "Mars",
            Answers = new List<string> { "Mars", "Venus", "Jupiter", "Saturn" }
        },
        new Question
        {
            Text = "What is 5 + 7?",
            CorrectAnswer = "12",
            Answers = new List<string> { "10", "11", "12", "13" }
        }
    };

    private int CurrentQuestionIndex = 0;
    private int Score = 0;
    private string? ResultMessage;
    private bool IsAnswered = false;

    private int TimeLeft = 10;
    private List<string> ShuffledAnswers = new List<string>();
    private Timer? QuestionTimer;

    protected override void OnInitialized()
    {
        StartQuestion();
    }

    private void StartQuestion()
    {
        IsAnswered = false;
        ResultMessage = null;
        TimeLeft = 10;
        
        var rnd = new Random();
        ShuffledAnswers = CurrentQuestion.Answers.OrderBy(a => rnd.Next()).ToList();
        
        QuestionTimer?.Dispose();
        QuestionTimer = new Timer(1000);
        QuestionTimer.Elapsed += async (s, e) =>
        {
            if (!IsAnswered)
            {
                TimeLeft--;
                await InvokeAsync(StateHasChanged);

                if (TimeLeft <= 0)
                {
                    await CheckAnswer(null);
                }
            }
        };
        QuestionTimer.Start();
    }

    private async Task CheckAnswer(string? selectedAnswer)
    {
        if (IsAnswered) return;

        IsAnswered = true;
        QuestionTimer?.Stop();

        if (selectedAnswer == CurrentQuestion.CorrectAnswer)
        {
            Score += 10 + TimeLeft;
            ResultMessage = $"Correct! 🎉 (+{10 + TimeLeft} points)";
        }
        else
        {
            ResultMessage = $"Wrong! The correct answer was: {CurrentQuestion.CorrectAnswer}";
        }

        await InvokeAsync(StateHasChanged);
        await Task.Delay(1500);

        CurrentQuestionIndex++;
        if (CurrentQuestionIndex < Questions.Count)
        {
            StartQuestion();
        }
        else
        {
            ResultMessage = null;
            StateHasChanged();
        }
    }

    private Question CurrentQuestion => Questions[CurrentQuestionIndex];
}
