@page "/multiplayer"
@using WebQuizGame.Classes.Models
@using WebQuizGame.Classes.Models.Multiplayer
@using WebQuizGame.Classes.Services
@inject MultiplayerClient Mp
@inject Authorization Auth
@inject NavigationManager Nav

<h2>Multiplayer</h2>

@if (!Auth.IsLoggedIn)
{
    <p>Pro multiplayer doporučuju být přihlášený (kvůli jménu). Jinak se použije "Guest".</p>
}

<div style="display:flex; gap:16px; flex-wrap:wrap;">
    <button class="menu-btn" @onclick="QuickMatchAny">Quick Match (Any)</button>
    <button class="menu-btn" @onclick="GoToCustomCreate">Create Custom Lobby</button>
    <button class="menu-btn" @onclick="GoToRanked">Ranked Multiplayer</button>
</div>

<hr />

<h3>Join Custom Lobby</h3>
<input placeholder="Lobby code" @bind="JoinCode" />
<button class="menu-btn" @onclick="JoinLobby">Join</button>

<hr />

<p>@Message</p>

@code {
    private string JoinCode = "";
    private string Message = "";

    protected override async Task OnInitializedAsync()
    {
        await Auth.InitializeAsync();
        await Mp.ConnectAsync("http://localhost:5237");
    }

    private string GetUsername()
    {
        if (!string.IsNullOrWhiteSpace(Auth.Username))
            return Auth.Username!;

        return "Guest_" + Guid.NewGuid().ToString("N").Substring(0, 4);
    }

    private async Task QuickMatchAny()
    {
        Message = "";
        var prefs = new LobbySettings(10, 10, "any", new List<int>());
        var state = await Mp.QuickMatchAsync(new QuickMatchRequest(GetUsername(), prefs));
        Nav.NavigateTo($"/lobby/{state.Code}");
    }

    private void GoToCustomCreate()
    {
        Nav.NavigateTo("/multiplayerCustomCreate");
    }

    private void GoToRanked()
    {
        Nav.NavigateTo("/multiplayerRanked");
    }

    private async Task JoinLobby()
    {
        Message = "";

        if (string.IsNullOrWhiteSpace(JoinCode))
        {
            Message = "Zadej kód lobby.";
            return;
        }

        var state = await Mp.JoinLobbyAsync(
            new JoinLobbyRequest(JoinCode.Trim().ToUpper(), GetUsername()));

        Nav.NavigateTo($"/multiplayerCustomLobby/{state.Code}");
    }
}