@page "/multiplayerCustomLobby/{Code}"
@using WebQuizGame.Classes.Models
@using WebQuizGame.Classes.Models.Multiplayer
@using WebQuizGame.Classes.Services
@inject MultiplayerClient Mp
@inject Authorization Auth
@inject NavigationManager Nav
@implements IDisposable

<h2>Custom Lobby</h2>

@if (State == null)
{
    <p>Loading lobby...</p>
}
else
{
    <p><strong>Lobby Code:</strong> @State.Code</p>
    <p><strong>Host:</strong> @State.HostUsername</p>
    <p><strong>Players (@State.Players.Count/4):</strong> @string.Join(", ", State.Players)</p>

    @if (!string.IsNullOrWhiteSpace(GameError))
    {
        <p style="color:red"><strong>@GameError</strong></p>
    }

    <h3>Current Settings</h3>
    <p>Questions: @State.Settings.Amount</p>
    <p>Time per question: @(State.Settings.TimePerQuestion == 0 ? "∞" : $"{State.Settings.TimePerQuestion}s")</p>
    <p>Difficulty: @State.Settings.Difficulty</p>
    <p>Categories: @(State.Settings.CategoryIds.Count == 0 ? "Any" : string.Join(", ", State.Settings.CategoryIds))</p>

    @if (IsHost && !State.IsStarted)
    {
        <hr />
        <h3>Host Settings</h3>

        <label>
            Number of questions: @(QuestionCount == MaxQuestionCount ? "∞" : QuestionCount.ToString())
        </label>
        <input type="range" min="5" max="@MaxQuestionCount" step="1"
               @bind="QuestionCount"
               @bind:event="oninput" />

        <label>
            Time per question:
            <select @bind="TimePerQuestion">
                <option value="5">5 s</option>
                <option value="10">10 s</option>
                <option value="15">15 s</option>
                <option value="30">30 s</option>
                <option value="60">60 s</option>
                <option value="120">120 s</option>
                <option value="0">Infinite</option>
            </select>
        </label>

        <div>
            <p>Select Categories (max 3):</p>
            @foreach (var cat in Categories)
            {
                <label style="display:block;">
                    <input type="checkbox"
                           @onchange="() => ToggleCategory(cat.Id)"
                           checked="@SelectedCategoryIds.Contains(cat.Id)"
                           disabled="@(!SelectedCategoryIds.Contains(cat.Id) && SelectedCategoryIds.Count >= 3)" />
                    @cat.Name
                </label>
            }
        </div>

        <div>
            <p>Difficulty:</p>
            @foreach (var diff in Difficulties)
            {
                <label style="display:block;">
                    <input type="radio" name="difficulty" value="@diff"
                           @onchange="() => SelectedDifficulty = diff"
                           checked="@SelectedDifficulty == diff" />
                    @diff
                </label>
            }
        </div>

        <button class="menu-btn" @onclick="ApplySettings">Apply Settings</button>
        <button class="menu-btn" @onclick="StartGame" disabled="@(State.Players.Count < 2)">
            Start Game
        </button>
    }

    @if (!IsHost && !State.IsStarted)
    {
        <p>Waiting for host to start the game...</p>
    }

    @if (State.IsStarted)
    {
        <p><strong>Game starting...</strong></p>
    }
}

@code {
    [Parameter] public string Code { get; set; } = "";

    private LobbyState? State;
    private bool _navigated = false;
    private string? GameError;

    private const int MaxQuestionCount = 50;
    private int QuestionCount = 10;
    private int TimePerQuestion = 10;
    private List<int> SelectedCategoryIds = new();
    private List<string> Difficulties = new() { "any", "easy", "medium", "hard" };
    private string SelectedDifficulty = "any";

    private bool IsHost => State != null && State.HostUsername == Mp.LocalUsername;

    private List<Category> Categories = new()
    {
        new Category { Id = 9,  Name = "General Knowledge" },
        new Category { Id = 10, Name = "Entertainment: Books" },
        new Category { Id = 11, Name = "Entertainment: Film" },
        new Category { Id = 12, Name = "Entertainment: Music" },
        new Category { Id = 13, Name = "Entertainment: Musicals & Theatres" },
        new Category { Id = 14, Name = "Entertainment: Television" },
        new Category { Id = 15, Name = "Entertainment: Video Games" },
        new Category { Id = 16, Name = "Entertainment: Board Games" },
        new Category { Id = 17, Name = "Science & Nature" },
        new Category { Id = 18, Name = "Science: Computers" },
        new Category { Id = 19, Name = "Science: Mathematics" },
        new Category { Id = 20, Name = "Mythology" },
        new Category { Id = 21, Name = "Sports" },
        new Category { Id = 22, Name = "Geography" },
        new Category { Id = 23, Name = "History" },
        new Category { Id = 24, Name = "Politics" },
        new Category { Id = 25, Name = "Art" },
        new Category { Id = 26, Name = "Celebrities" },
        new Category { Id = 27, Name = "Animals" },
        new Category { Id = 28, Name = "Vehicles" },
        new Category { Id = 29, Name = "Entertainment: Comics" },
        new Category { Id = 30, Name = "Science: Gadgets" },
        new Category { Id = 31, Name = "Entertainment: Japanese Anime & Manga" },
        new Category { Id = 32, Name = "Entertainment: Cartoon & Animations" }
    };

    protected override async Task OnInitializedAsync()
    {
        await Auth.InitializeAsync();
        await Mp.ConnectAsync("http://localhost:5237");

        Mp.OnLobbyUpdated += HandleLobbyUpdated;
        Mp.OnGameError += HandleGameError;
        Mp.OnNewQuestion += HandleNewQuestion;

        State = await Mp.GetLobbyStateAsync(Code);

        if (State != null)
        {
            QuestionCount = State.Settings.Amount;
            TimePerQuestion = State.Settings.TimePerQuestion;
            SelectedDifficulty = State.Settings.Difficulty;
            SelectedCategoryIds = State.Settings.CategoryIds.ToList();
        }
    }

    private void HandleLobbyUpdated(LobbyState s)
    {
        if (s.Code != Code) return;

        State = s;
        QuestionCount = s.Settings.Amount;
        TimePerQuestion = s.Settings.TimePerQuestion;
        SelectedDifficulty = s.Settings.Difficulty;
        SelectedCategoryIds = s.Settings.CategoryIds.ToList();

        if (State.IsStarted && !_navigated)
        {
            _navigated = true;
            Nav.NavigateTo($"/multiplayerGame/{Code}");
            return;
        }

        InvokeAsync(StateHasChanged);
    }

    private void HandleGameError(string msg)
    {
        GameError = msg;
        InvokeAsync(StateHasChanged);
    }

    private async void HandleNewQuestion(TriviaQuestion q)
    {
        if (_navigated) return;
        _navigated = true;
        await Task.Delay(100);
        Nav.NavigateTo($"/multiplayerGame/{Code}");
    }

    private void ToggleCategory(int id)
    {
        if (SelectedCategoryIds.Contains(id))
            SelectedCategoryIds.Remove(id);
        else
            SelectedCategoryIds.Add(id);
    }

    private async Task ApplySettings()
    {
        var settings = new LobbySettings(
            QuestionCount,
            TimePerQuestion,
            SelectedDifficulty,
            SelectedCategoryIds.ToList());

        await Mp.UpdateSettingsAsync(Code, settings);
    }

    private async Task StartGame()
    {
        await Mp.StartGameAsync(Code);
    }

    public void Dispose()
    {
        Mp.OnLobbyUpdated -= HandleLobbyUpdated;
        Mp.OnGameError -= HandleGameError;
        Mp.OnNewQuestion -= HandleNewQuestion;
    }
}