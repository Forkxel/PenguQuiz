@page "/leaderboard"
@using WebQuizGame.Classes.Models
@inject HttpClient Http
@inject NavigationManager Navigation

<div class="leaderboard-page">
    <div class="leaderboard-screen">
        <h1 class="leaderboard-title">@(ShowMulti ? "Multiplayer Ranked Leaderboard" : "Singleplayer Ranked Leaderboard")</h1>
        <p class="leaderboard-subtitle">Top ranked players overview</p>

        <div class="leaderboard-switch">
            <button class="menu-btn" @onclick="ShowSingleLeaderboard" disabled="@(!ShowMulti)">
                Single Ranked
            </button>

            <button class="menu-btn" @onclick="ShowMultiLeaderboard" disabled="@(ShowMulti)">
                Multi Ranked
            </button>
        </div>

        @if (IsLoading)
        {
            <div class="leaderboard-card">
                <p class="leaderboard-message">Loading leaderboard...</p>
            </div>
        }
        else if (Entries == null || Entries.Count == 0)
        {
            <div class="leaderboard-card">
                <p class="leaderboard-message">No leaderboard data found.</p>
            </div>
        }
        else
        {
            <div class="leaderboard-card leaderboard-table-wrap">
                <table class="leaderboard-table">
                    <thead>
                        <tr>
                            <th>Rank</th>
                            <th>Username</th>
                            <th>Elo</th>
                            <th>Played</th>
                            <th>Wins</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var entry in Entries)
                        {
                            <tr>
                                <td>@entry.Rank</td>
                                <td>@entry.Username</td>
                                <td>@(ShowMulti ? entry.MultiElo : entry.SingleElo)</td>
                                <td>@(ShowMulti ? entry.MultiRankedPlayed : entry.SingleRankedPlayed)</td>
                                <td>@(ShowMulti ? entry.MultiRankedWins : entry.SingleRankedWins)</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }

        @if (!string.IsNullOrWhiteSpace(Message))
        {
            <div class="leaderboard-error-box">
                <p class="leaderboard-message">@Message</p>
            </div>
        }

        <div class="leaderboard-actions">
            <button class="menu-btn leaderboard-back-btn" @onclick="GoBack">Back to Menu</button>
        </div>
    </div>
</div>

@code {
    private List<LeaderboardEntryResponse>? Entries;
    private string Message = "";
    private bool ShowMulti = false;
    private bool IsLoading = true;

    protected override async Task OnInitializedAsync()
    {
        await LoadLeaderboard();
    }

    private async Task ShowSingleLeaderboard()
    {
        if (!ShowMulti)
            return;

        ShowMulti = false;
        await LoadLeaderboard();
    }

    private async Task ShowMultiLeaderboard()
    {
        if (ShowMulti)
            return;

        ShowMulti = true;
        await LoadLeaderboard();
    }

    private async Task LoadLeaderboard()
    {
        IsLoading = true;
        Message = "";
        Entries = null;

        var url = ShowMulti
            ? "api/ranked/leaderboard/multi?top=20"
            : "api/ranked/leaderboard/single?top=20";

        var response = await Http.GetAsync(url);

        if (!response.IsSuccessStatusCode)
        {
            var errorText = await response.Content.ReadAsStringAsync();
            Message = $"Failed to load leaderboard: {response.StatusCode} - {errorText}";
            Entries = new List<LeaderboardEntryResponse>();
            IsLoading = false;
            return;
        }

        Entries = await response.Content.ReadFromJsonAsync<List<LeaderboardEntryResponse>>()
                  ?? new List<LeaderboardEntryResponse>();

        IsLoading = false;
    }

    private void GoBack()
    {
        Navigation.NavigateTo("/");
    }
}